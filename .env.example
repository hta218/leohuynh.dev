# Analytics (Umami). Public ID exposed to the client.
PUBLIC_UMAMI_WEBSITE_ID=

# Spotify "now playing" rail. Server-side only — never expose with PUBLIC_.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# GitHub API for contributions / repo stats + the token-burn widget (reads the
# private hta218/token-burn repo). Server-side only — never expose with PUBLIC_.
GITHUB_API_TOKEN=

# Giscus comments (public).
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPOSITORY_ID=
PUBLIC_GISCUS_CATEGORY=
PUBLIC_GISCUS_CATEGORY_ID=

# Postgres database for persisted article/snippet views + reactions.
DATABASE_URL=
