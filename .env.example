# Analytics (Umami). Public ID exposed to the client.
PUBLIC_UMAMI_WEBSITE_ID=

# Spotify "now playing" rail. Server-side only — never expose with PUBLIC_.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# GitHub API for contributions / repo stats + the token burn widget.
GITHUB_API_TOKEN=

# Giscus comments (public).
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPOSITORY_ID=
PUBLIC_GISCUS_CATEGORY=
PUBLIC_GISCUS_CATEGORY_ID=

# Postgres database for persisted article/snippet views + reactions.
DATABASE_URL=

# Create an OAuth app at https://github.com/settings/developers, callback:
#   http://localhost:3434/api/auth/github/callback  (add prod URLs when deploying)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GUESTBOOK_SESSION_SECRET=
GUESTBOOK_ADMIN_GITHUB_LOGINS=
GUESTBOOK_AUTO_APPROVE=true
