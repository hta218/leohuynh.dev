---
import HugeIcon from '~/components/icons/HugeIcon.astro'
import { brandIcon } from '~/lib/brand-icons'
import type { Project } from '~/lib/projects'

interface Props {
  project: Project
}

const { project: p } = Astro.props
const href = p.repo ? `https://github.com/${p.repo}` : p.url
const isRepo = Boolean(p.repo)
// Repo cards are a single anchor to GitHub. Non-repo cards stay a <div> so the
// title and each link can be their own anchors.
const Tag = isRepo && href ? 'a' : 'div'

// Some tools share the same brand icon (e.g. "Shell" and "Bash" both render the
// Bash logo) — merge those into a single badge instead of showing it twice.
interface StackItem {
  title: string
  icon?: string
}
const stackItems: StackItem[] = []
const stackByKey = new Map<string, StackItem>()
for (const tool of p.builtWith) {
  const icon = brandIcon(tool)
  const key = icon ?? tool
  const existing = stackByKey.get(key)
  if (existing) {
    existing.title += `, ${tool}`
    continue
  }
  const item: StackItem = { title: tool, icon }
  stackByKey.set(key, item)
  stackItems.push(item)
}
---

<Tag
  href={isRepo ? href : undefined}
  target={isRepo && href ? '_blank' : undefined}
  rel={isRepo && href ? 'noreferrer' : undefined}
  data-project-repo={p.repo}
  class="group flex min-h-59.5 flex-col gap-3 rounded-2xl border border-line bg-white p-4 no-underline transition-shadow hover:shadow-[4px_4px_0_var(--color-line)]"
>
  <div class="flex items-center gap-3">
    {p.imgSrc ? (
      <img
        src={p.imgSrc}
        alt={p.title}
        width="40"
        height="40"
        loading="lazy"
        class="h-10 w-10 rounded-lg object-contain"
      />
    ) : (
      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-line bg-[#f8fafc] text-slate-500">
        <HugeIcon name={p.icon ?? 'code'} size={24} class="size-6! flex-none!" />
      </span>
    )}
    <div>
      <h3 class="m-0 text-[17px] font-semibold tracking-[-0.02em] text-ink group-hover:text-slate-950">
        {isRepo || !href ? (
          p.title
        ) : (
          <a
            href={href}
            target="_blank"
            rel="noreferrer"
            class="text-ink no-underline hover:text-slate-950 hover:underline"
          >
            {p.title}
          </a>
        )}
      </h3>
      {p.repo && (
        <div class="mt-1 font-mono text-[11px] text-muted" data-project-owner>
          {p.repo}
        </div>
      )}
    </div>
  </div>

  <p class="m-0 line-clamp-3 text-[15px] leading-snug text-muted" data-project-description>
    {p.description || 'Live GitHub metadata loads on demand.'}
  </p>

  <div
    class:list={[
      'mt-auto grid grid-cols-2 gap-3 border-t border-line pt-3 font-mono text-xs text-muted',
      p.repo && 'sm:grid-cols-3',
    ]}
  >
    {isRepo ? (
      <div>
        <div class="text-[10px] uppercase tracking-[0.08em] text-slate-400">Stars</div>
        <div class="mt-1 flex items-center gap-1.5 text-slate-900">
          <HugeIcon name="star" class="text-slate-500" />
          <span data-project-stars>—</span>
        </div>
      </div>
    ) : (
      <div class="min-w-0">
        <div class="text-[10px] uppercase tracking-[0.08em] text-slate-400">Links</div>
        <div class="mt-1 flex min-h-5 flex-wrap items-center gap-x-3 gap-y-1 text-slate-900">
          {(p.links?.length
            ? p.links
            : href
              ? [{ title: 'Website', url: href }]
              : []
          ).map((l) => (
            <a
              href={l.url}
              target="_blank"
              rel="noreferrer"
              class="flex items-center gap-1 whitespace-nowrap text-slate-900 no-underline hover:text-slate-950 hover:underline"
            >
              <span class="text-slate-400">↗</span>
              <span>{l.title}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <div>
      <div class="text-[10px] uppercase tracking-[0.08em] text-slate-400">Stack</div>
      <div class="mt-1 flex min-h-5 flex-wrap items-center gap-1.5 text-slate-900">
        {stackItems.map((item) =>
          item.icon ? (
            <span class="tech-icon" title={item.title} set:html={item.icon} />
          ) : (
            <span class="text-[11px] text-slate-500">{item.title}</span>
          ),
        )}
      </div>
    </div>

    {p.repo && (
      <div>
        <div class="text-[10px] uppercase tracking-[0.08em] text-slate-400" data-project-meta-label>
          Language
        </div>
        <div class="mt-1 flex h-5 items-center gap-1.5 truncate text-slate-900" data-project-meta>
          loading…
        </div>
      </div>
    )}
  </div>
</Tag>
