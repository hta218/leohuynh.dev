---
/**
 * Shared, framed code block for hand-authored snippets (e.g. the home build log).
 * Reuses the same `CodeToolbar` controls and frame treatment as the toolbar that
 * gets injected into Expressive Code blocks, so the two stay visually identical.
 */
import CodeToolbar from './CodeToolbar.astro'

interface Props {
  /** Filename / label shown on the left of the header. */
  title?: string
}

const { title = 'output' } = Astro.props
---

<figure class="codeblock">
  <figcaption class="codeblock-header">
    <span class="codeblock-title">
      <span class="codeblock-dots" aria-hidden="true"></span>
      {title}
    </span>
    <CodeToolbar />
  </figcaption>
  <pre class="codeblock-pre"><slot /></pre>
</figure>

<style is:global>
  .codeblock {
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: 12px;
    background: var(--color-panel2);
    box-shadow: 3px 3px 0 var(--color-line);
  }

  .codeblock-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    border-bottom: 1px solid var(--color-line);
    background: var(--color-panel);
    padding: 7px 10px 7px 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted);
  }

  .codeblock-title {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .codeblock-dots {
    display: inline-block;
    width: 38px;
    height: 10px;
    flex: none;
    background-image: radial-gradient(circle, #f87171 4px, transparent 4.5px),
      radial-gradient(circle, #fbbf24 4px, transparent 4.5px),
      radial-gradient(circle, #34d399 4px, transparent 4.5px);
    background-size: 14px 10px;
    background-position: left center, center center, right center;
    background-repeat: no-repeat;
  }

  .codeblock-pre {
    overflow: auto;
    margin: 0;
    padding: 16px 18px;
    background: #0f172a;
    color: #e5e7eb;
    font-family: var(--code-font-family);
    font-size: 13px;
    line-height: 1.75;
  }
</style>
