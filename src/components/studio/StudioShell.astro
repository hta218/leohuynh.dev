---
import { getCollection } from 'astro:content'
import { execSync } from 'node:child_process'
import HugeIcon from '~/components/icons/HugeIcon.astro'
import { getDotfilesTree } from '~/lib/dotfiles'
import { SITE } from '~/lib/site'
import AstroIcon from '@icons/astro.svg?raw'
import GoodreadsIcon from '@icons/goodreads.svg?raw'
import ImdbIcon from '@icons/imdb.svg?raw'
import MarkdownIcon from '@icons/markdown.svg?raw'
import UmamiIcon from '@icons/umami.svg?raw'
import DotfilesNav from './DotfilesNav.astro'
import RuntimeRail from './RuntimeRail.astro'

interface Props {
  /** path used to highlight the active explorer entry, e.g. "/blog" */
  active?: string
  /** breadcrumb shown above the main content, e.g. "~/leohuynh.dev/main" */
  crumb?: string
}

type BrandIconName = 'astro' | 'goodreads' | 'imdb' | 'markdown' | 'umami'
type HugeIconName =
  | 'analytics'
  | 'book'
  | 'caret-down'
  | 'caret-right'
  | 'comment'
  | 'external'
  | 'file'
  | 'folder'
  | 'folder-open'
  | 'gallery'
  | 'keyboard'
  | 'markdown'
  | 'project'
  | 'quill'
  | 'rocket'
  | 'star'
  | 'tag'
  | 'user'
  | 'code'
type IconSpec =
  | { type: 'brand'; name: BrandIconName }
  | { type: 'huge'; name: HugeIconName }

type TreeLeaf = {
  kind: 'leaf'
  id: string
  href: string
  file: string
  title?: string
  icon: IconSpec
  external?: boolean
  openHint?: boolean
  activeWhen?: (path: string) => boolean
}

type TreeFolder = {
  kind: 'folder'
  id: string
  href?: string
  file: string
  title?: string
  icon: IconSpec
  children: TreeLeaf[]
  activeWhen?: (path: string) => boolean
}

type TreeItem = TreeLeaf | TreeFolder

const { active, crumb = '~/leohuynh.dev/main' } = Astro.props
const currentPath = (active ?? Astro.url.pathname.replace(/\/$/, '')) || '/'
const isExternal = (href: string) => href.startsWith('http')
const isPublished = (d: { data: { draft?: boolean } }) => d.data.draft !== true

const BRAND_ICONS: Record<BrandIconName, string> = {
  astro: AstroIcon,
  goodreads: GoodreadsIcon,
  imdb: ImdbIcon,
  markdown: MarkdownIcon,
  umami: UmamiIcon,
}

const [posts, snippets] = await Promise.all([
  getCollection('blog', isPublished),
  getCollection('snippets', isPublished),
])

const latestPost = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)[0]
const latestSnippet = snippets.sort((a, b) => b.id.localeCompare(a.id))[0]

const exact = (href: string) => (path: string) => path === href
const startsWith = (prefix: string) => (path: string) =>
  path === prefix || path.startsWith(`${prefix}/`)

const postsIndex: TreeLeaf = {
  kind: 'leaf',
  id: 'posts-index',
  href: '/log',
  file: 'index.astro',
  title: 'Posts index',
  icon: { type: 'brand', name: 'astro' },
  activeWhen: (path) => path === '/log' || path.startsWith('/log/page/'),
}
const postsSlug: TreeLeaf = {
  kind: 'leaf',
  id: 'posts-slug',
  href: latestPost ? `/log/${latestPost.id}` : '/log',
  file: '[...slug].astro',
  title: 'Post detail template',
  icon: { type: 'brand', name: 'astro' },
  activeWhen: (path) =>
    path.startsWith('/log/') && !path.startsWith('/log/page/'),
}
const snippetsIndex: TreeLeaf = {
  kind: 'leaf',
  id: 'snippets-index',
  href: '/gists',
  file: 'index.astro',
  title: 'Snippets index',
  icon: { type: 'brand', name: 'astro' },
  activeWhen: exact('/gists'),
}
const snippetsSlug: TreeLeaf = {
  kind: 'leaf',
  id: 'snippets-slug',
  href: latestSnippet ? `/gists/${latestSnippet.id}` : '/gists',
  file: '[...slug].astro',
  title: 'Snippet detail template',
  icon: { type: 'brand', name: 'astro' },
  activeWhen: (path) => path.startsWith('/gists/'),
}

const explorerItems: TreeItem[] = [
  {
    kind: 'leaf',
    id: 'readme',
    href: '/',
    file: 'README.md',
    title: 'Home',
    icon: { type: 'brand', name: 'markdown' },
    activeWhen: exact('/'),
  },
  {
    kind: 'folder',
    id: 'posts-folder',
    file: 'logs',
    title: 'Logs',
    icon: { type: 'huge', name: 'folder' },
    children: [postsIndex, postsSlug],
    activeWhen: startsWith('/log'),
  },
  {
    kind: 'folder',
    id: 'snippets-folder',
    file: 'gists',
    title: 'Gists',
    icon: { type: 'huge', name: 'folder' },
    children: [snippetsIndex, snippetsSlug],
    activeWhen: startsWith('/gists'),
  },
  {
    kind: 'leaf',
    id: 'projects',
    href: '/builds',
    file: 'builds.astro',
    title: 'Builds',
    icon: { type: 'huge', name: 'rocket' },
    activeWhen: exact('/builds'),
  },
  {
    kind: 'leaf',
    id: 'about',
    href: '/whoami',
    file: 'whoami',
    title: 'whoami',
    icon: { type: 'brand', name: 'markdown' },
    activeWhen: exact('/whoami'),
  },
  {
    kind: 'leaf',
    id: 'shelf',
    href: '/shelf',
    file: 'shelf.astro',
    title: 'Shelf',
    icon: { type: 'huge', name: 'gallery' },
    activeWhen: startsWith('/shelf'),
  },
  {
    kind: 'leaf',
    id: 'tags',
    href: '/topics',
    file: 'topics',
    title: 'Topics',
    icon: { type: 'huge', name: 'tag' },
    activeWhen: startsWith('/topics'),
  },
  {
    kind: 'leaf',
    id: 'guestbook',
    href: '/guestbook',
    file: 'guestbook.astro',
    title: 'Guestbook',
    icon: { type: 'huge', name: 'quill' },
    activeWhen: exact('/guestbook'),
  },
  {
    kind: 'leaf',
    id: 'stats',
    href: SITE.analytics.umamiShareUrl,
    file: 'stats',
    title: 'Stats',
    icon: { type: 'brand', name: 'umami' },
    external: true,
    openHint: true,
  },
]

const rawDotfilesTree = await getDotfilesTree()
// Hoist the root README to the top of the group so it reads like a landing entry.
const dotfilesTree = [...rawDotfilesTree].sort((a, b) => {
  if (a.path === 'README.md') return -1
  if (b.path === 'README.md') return 1
  return 0
})
const activeDotfile =
  currentPath === '/dotfiles'
    ? ''
    : currentPath.startsWith('/dotfiles/')
      ? decodeURIComponent(currentPath.slice('/dotfiles/'.length))
      : undefined

const tabLinks: TreeLeaf[] = [
  explorerItems.find(
    (item) => item.kind === 'leaf' && item.id === 'readme',
  ) as TreeLeaf,
  { ...postsIndex, file: 'log/index.astro' },
  { ...snippetsIndex, file: 'gists/index.astro' },
  explorerItems.find(
    (item) => item.kind === 'leaf' && item.id === 'projects',
  ) as TreeLeaf,
  explorerItems.find(
    (item) => item.kind === 'leaf' && item.id === 'about',
  ) as TreeLeaf,
]

const shellId = `studio-${Math.random().toString(36).slice(2)}`
const isActive = (item: {
  href: string
  activeWhen?: (path: string) => boolean
}) =>
  item.activeWhen ? item.activeWhen(currentPath) : currentPath === item.href
const renderCommit = () => {
  const sha = process.env.VERCEL_GIT_COMMIT_SHA?.slice(0, 7)
  if (sha) return sha
  try {
    return execSync('git rev-parse --short HEAD', { encoding: 'utf8' }).trim()
  } catch {
    return 'local'
  }
}
const renderCommitDate = () => {
  const envDate = process.env.VERCEL_GIT_COMMIT_AUTHOR_DATE
  if (envDate) return envDate
  try {
    return execSync('git log -1 --format=%cI', { encoding: 'utf8' }).trim()
  } catch {
    return new Date().toISOString()
  }
}
const lastCommit = renderCommit()
const lastCommitDate = renderCommitDate()
const lastCommitUrl =
  lastCommit && lastCommit !== 'local'
    ? `${SITE.siteRepo}/commit/${lastCommit}`
    : SITE.siteRepo
const SITE_VERSIONS = [
  {
    value: 'latest',
    branch: 'main',
    label: 'Astro × bun',
    href: '/',
    current: true,
  },
  {
    value: 'v3',
    branch: 'v3',
    label: 'Next.js 15 × pnpm',
    href: 'https://v3.leohuynh.dev/',
  },
  {
    value: 'v2',
    branch: 'v2',
    label: 'Next.js 14 × npm',
    href: 'https://v2.leohuynh.dev/',
  },
  {
    value: 'v1',
    branch: 'v1',
    label: 'Gatsby × yarn',
    href: 'https://v1.leohuynh.dev/',
  },
]
const currentBranch = SITE_VERSIONS.find((v) => v.current)?.branch ?? 'main'
const GIT_BRANCH_ICON =
  '<svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M9.5 3.25a2.25 2.25 0 1 1 3 2.122V6A2.5 2.5 0 0 1 10 8.5H6a1 1 0 0 0-1 1v1.128a2.251 2.251 0 1 1-1.5 0V5.372a2.25 2.25 0 1 1 1.5 0v1.836A2.493 2.493 0 0 1 6 7h4a1 1 0 0 0 1-1v-.628A2.25 2.25 0 0 1 9.5 3.25Zm-6 0a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Zm8.25-.75a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5ZM4.25 12a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Z"></path></svg>'
---

<div id={shellId} class="studio-shell grid h-screen grid-rows-[1fr_32px] overflow-hidden bg-bg" data-rail="visible">
  <div class="studio-workspace grid min-h-0 grid-cols-1 overflow-hidden lg:grid-cols-[260px_minmax(0,1fr)_360px]">
    <aside class="thin-scrollbar hidden min-h-0 overflow-y-auto border-r border-line bg-[#f8fafc] px-3 py-3 lg:block">
      <a href="/" class="mb-4 flex items-center gap-2.5 font-extrabold no-underline text-ink">
        <span class="flex h-9 w-9 items-center justify-center rounded-xl border border-ink bg-white font-mono text-base shadow-[3px_3px_0_var(--color-ink)]">~/</span>
        <span>leohuynh.dev</span>
      </a>

      <section class="mb-4" data-folder="section-explorer">
        <button
          type="button"
          data-folder-toggle="section-explorer"
          aria-expanded="true"
          class="sidebar-section-header mb-2"
        >
          <span>explorer</span>
          <span class="section-toggle" aria-hidden="true" />
        </button>
        <nav class="space-y-0.5" data-folder-children="section-explorer">
          {
            explorerItems.map((item) => (
              <div data-folder={item.kind === 'folder' ? item.id : undefined}>
                {item.kind === 'folder' ? (
                  <>
                    <button
                      type="button"
                      data-folder-toggle={item.id}
                      aria-expanded="true"
                      class="explorer-row explorer-folder-row py-1.5 text-left font-mono text-[13px] text-slate-600 hover:bg-slate-100 hover:text-slate-950"
                    >
                      <HugeIcon name="caret-down" class="explorer-caret text-slate-500" />
                      <span class="explorer-icon text-slate-500">
                        <HugeIcon name="folder-open" class="folder-icon-open" />
                        <HugeIcon name="folder" class="folder-icon-closed" />
                      </span>
                      <span>{item.file}</span>
                    </button>
                    <div class="mt-0.5 space-y-0.5" data-folder-children={item.id}>
                      {item.children.map((child) => (
                        <a
                          href={child.href}
                          class:list={[
                            'explorer-row explorer-row--child py-1.5 font-mono text-[13px] no-underline',
                            isActive(child)
                              ? 'bg-slate-200 text-slate-950'
                              : 'text-slate-600 hover:bg-slate-100 hover:text-slate-950',
                          ]}
                        >
                          <span class="explorer-caret" aria-hidden="true" />
                          {child.icon.type === 'brand' ? (
                            <span class="brand-icon explorer-icon text-slate-500" set:html={BRAND_ICONS[child.icon.name]} />
                          ) : (
                            <HugeIcon name={child.icon.name} class="explorer-icon text-slate-500" />
                          )}
                          <span>{child.file}</span>
                        </a>
                      ))}
                    </div>
                  </>
                ) : (
                  <a
                    href={item.href}
                    target={item.external || isExternal(item.href) ? '_blank' : undefined}
                    rel={item.external || isExternal(item.href) ? 'noreferrer' : undefined}
                    class:list={[
                      'explorer-row group py-1.5 font-mono text-[13px] no-underline',
                      isActive(item)
                        ? 'bg-slate-200 text-slate-950'
                        : 'text-slate-600 hover:bg-slate-100 hover:text-slate-950',
                    ]}
                  >
                    <span class="explorer-caret" aria-hidden="true" />
                    {item.icon.type === 'brand' ? (
                      <span class="brand-icon explorer-icon text-slate-500" set:html={BRAND_ICONS[item.icon.name]} />
                    ) : (
                      <HugeIcon name={item.icon.name} class="explorer-icon text-slate-500" />
                    )}
                    <span>{item.file}</span>
                    {item.openHint && <HugeIcon name="external" class="ml-auto opacity-0 transition-opacity group-hover:opacity-100" size={13} />}
                  </a>
                )}
              </div>
            ))
          }
        </nav>
      </section>

      <section class="mb-4" data-folder="section-dotfiles">
        <button
          type="button"
          data-folder-toggle="section-dotfiles"
          aria-expanded="true"
          class="sidebar-section-header mb-2"
        >
          <span>dotfiles</span>
          <span class="section-toggle" aria-hidden="true" />
        </button>
        <nav class="space-y-0.5" data-folder-children="section-dotfiles">
          <DotfilesNav nodes={dotfilesTree} currentPath={activeDotfile} />
        </nav>
      </section>
    </aside>

    <main class="flex min-h-0 min-w-0 flex-col overflow-hidden bg-panel [background-image:linear-gradient(90deg,rgba(15,23,42,0.03)_1px,transparent_1px)] [background-size:64px_64px]">
      <nav class="flex shrink-0 items-stretch border-b border-line bg-[#fbfcff]">
        <div class="thin-scrollbar flex min-w-0 flex-1 overflow-x-auto">
          {
            tabLinks.map((l) => (
              <a
                href={l.href}
                class:list={[
                  'tab-row shrink-0 border-r border-line px-3.5 py-2.5 font-mono text-xs no-underline',
                  isActive(l)
                    ? 'bg-white text-slate-950 shadow-[inset_0_-2px_0_var(--color-ink)]'
                    : 'text-muted hover:text-slate-950',
                ]}
              >
                {l.icon.type === 'brand' ? (
                  <span class="brand-icon tab-icon text-slate-500" set:html={BRAND_ICONS[l.icon.name]} />
                ) : (
                  <HugeIcon name={l.icon.name} class="tab-icon text-slate-500" />
                )}
                {l.file}
              </a>
            ))
          }
        </div>
        <button
          type="button"
          class="hidden shrink-0 border-l border-line bg-[#fbfcff] px-3.5 py-2.5 font-mono text-xs text-muted hover:bg-white hover:text-slate-950 lg:block"
          data-toggle-rail
          aria-controls="runtime-rail"
          aria-expanded="true"
        >
          hide right rail
        </button>
      </nav>

      <div class="thin-scrollbar min-h-0 flex-1 overflow-y-auto px-[clamp(22px,5vw,78px)] pt-9.5 pb-17.5">
        <div class="mb-4.5 font-mono text-xs text-slate-500">{crumb}</div>
        <slot />
      </div>
    </main>

    <RuntimeRail />
  </div>

  <footer class="studio-statusbar flex min-w-0 items-center justify-between gap-3 border-t border-line bg-white px-3 font-mono text-[12px] text-slate-600">
    <div class="flex min-w-0 items-center gap-3">
      <div class="version-menu" data-version-menu>
        <button
          type="button"
          class="version-trigger"
          data-version-trigger
          aria-haspopup="menu"
          aria-expanded="false"
          aria-label="Switch site version (git branch)"
          title="Switch site version"
        >
          <span class="git-branch-icon" set:html={GIT_BRANCH_ICON} />
          <span>{currentBranch}</span>
          <svg class="version-caret" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6 15l6-6 6 6" />
          </svg>
        </button>
        <div class="version-popover" data-version-popover role="menu" hidden>
          <div class="version-popover-title">Checkout version</div>
          {
            SITE_VERSIONS.map((version) => (
              <a
                href={version.href}
                target={version.value === 'latest' ? '_self' : '_blank'}
                rel="noreferrer"
                class="version-item"
                role="menuitem"
                data-version-item
                aria-current={version.current ? 'true' : undefined}
              >
                <span class="git-branch-icon" set:html={GIT_BRANCH_ICON} />
                <span class="version-item-branch">{version.branch}</span>
                <span class="version-item-label">{version.label}</span>
                {version.current && <span class="version-item-check" aria-hidden="true">✓</span>}
              </a>
            ))
          }
        </div>
      </div>
      <a
        href={lastCommitUrl}
        target="_blank"
        rel="noreferrer"
        class="hidden whitespace-nowrap text-slate-950 underline decoration-slate-300 underline-offset-3 hover:decoration-slate-950 sm:inline"
        title="View last commit on GitHub"
        data-commit-time={lastCommitDate}
      >
        #{lastCommit}
        <span class="text-slate-400" data-commit-ago>—</span>
      </a>
    </div>
    <div class="flex shrink-0 items-center gap-3">
      <a
        href="https://time.is/Hanoi"
        target="_blank"
        rel="noreferrer"
        class="whitespace-nowrap text-slate-700 underline decoration-slate-300 underline-offset-3 hover:text-slate-950"
        data-local-time-link
      >
        Hanoi <span data-local-time>--:--</span> <span class="text-slate-400" data-local-time-diff></span>
      </a>
    </div>
  </footer>
</div>

<script is:inline>
  const LANG_ICONS = {
    ts: `<svg viewBox="0 0 128 128" width="14" height="14" fill="currentColor"><path d="M2 63.91v62.5h125v-125H2zm100.73-5a15.56 15.56 0 017.82 4.5 20.58 20.58 0 013 4c0 .16-5.4 3.81-8.69 5.85-.12.08-.6-.44-1.13-1.23a7.09 7.09 0 00-5.87-3.53c-3.79-.26-6.23 1.73-6.21 5a4.58 4.58 0 00.54 2.34c.83 1.73 2.38 2.76 7.24 4.86 8.95 3.85 12.78 6.39 15.16 10 2.66 4 3.25 10.46 1.45 15.24-2 5.2-6.9 8.73-13.83 9.9a38.32 38.32 0 01-9.52-.1A23 23 0 0180 109.19c-1.15-1.27-3.39-4.58-3.25-4.82a9.34 9.34 0 011.15-.73l4.6-2.64 3.59-2.08.75 1.11a16.78 16.78 0 004.74 4.54c4 2.1 9.46 1.81 12.16-.62a5.43 5.43 0 00.69-6.92c-1-1.39-3-2.56-8.59-5-6.45-2.78-9.23-4.5-11.77-7.24a16.48 16.48 0 01-3.43-6.25 25 25 0 01-.22-8c1.33-6.23 6-10.58 12.82-11.87a31.66 31.66 0 019.49.26zm-29.34 5.24v5.12H57.16v46.23H45.65V69.26H29.38v-5a49.19 49.19 0 01.14-5.16c.06-.08 10-.12 22-.1h21.81z"/></svg>`,
    js: `<svg viewBox="0 0 128 128" width="14" height="14" fill="currentColor"><path d="M116.347 96.736c-.917-5.711-4.641-10.508-15.672-14.981-3.832-1.761-8.104-3.022-9.377-5.926-.452-1.69-.512-2.642-.226-3.665.821-3.32 4.784-4.355 7.925-3.403 2.023.678 3.938 2.237 5.093 4.724 5.402-3.498 5.391-3.475 9.163-5.879-1.381-2.141-2.118-3.129-3.022-4.045-3.249-3.629-7.676-5.498-14.756-5.355l-3.688.477c-3.534.893-6.902 2.748-8.877 5.235-5.926 6.724-4.236 18.492 2.975 23.335 7.104 5.332 17.54 6.545 18.873 11.531 1.297 6.104-4.486 8.08-10.234 7.378-4.236-.881-6.592-3.034-9.139-6.949-4.688 2.713-4.688 2.713-9.508 5.485 1.143 2.499 2.344 3.63 4.26 5.795 9.068 9.198 31.76 8.746 35.83-5.176.165-.478 1.261-3.666.38-8.581zM69.462 58.943H57.753l-.048 30.272c0 6.438.333 12.34-.714 14.149-1.713 3.558-6.152 3.117-8.175 2.427-2.059-1.012-3.106-2.451-4.319-4.485-.333-.584-.583-1.036-.667-1.071l-9.52 5.83c1.583 3.249 3.915 6.069 6.902 7.901 4.462 2.678 10.459 3.499 16.731 2.059 4.082-1.189 7.604-3.652 9.448-7.401 2.666-4.915 2.094-10.864 2.07-17.444.06-10.735.001-21.468.001-32.237z"/></svg>`,
