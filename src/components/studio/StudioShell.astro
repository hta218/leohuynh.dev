  function initStudioShell() {
    const root = document.documentElement
    const syncCodeControls = () => {
      const theme = localStorage.getItem('leohuynh:code-theme') || 'github-light-default'
      const font = localStorage.getItem('leohuynh:code-font') || 'ui-mono'
      root.dataset.theme = theme
      root.dataset.codeFont = font
      document.querySelectorAll('[data-code-theme-select]').forEach((select) => {
        select.value = theme
      })
      document.querySelectorAll('[data-code-font-select]').forEach((select) => {
        select.value = font
      })
    }

    document.querySelectorAll('.expressive-code figure.frame').forEach((frame) => {
      if (frame.querySelector('.ec-code-toolbar')) return
      const figcaption = frame.querySelector('figcaption.header')
      if (!figcaption) return
      const pre = frame.querySelector('pre[data-language]')
      const langAttr = pre?.getAttribute('data-language') || ''
      const titleEl = figcaption.querySelector('.title')
      if (langAttr) {
        const aliases = { tsx: 'ts', typescript: 'ts', jsx: 'js', javascript: 'js', mjs: 'js', cjs: 'js', scss: 'css', sass: 'css', sh: 'bash', shell: 'bash', zsh: 'bash', mdx: 'md', markdown: 'md' }
        const iconKey = aliases[langAttr] || langAttr
        const icon = LANG_ICONS[iconKey]
        const badge = document.createElement('span')
        if (icon) {
          badge.className = 'ec-lang-badge ec-lang-icon'
          badge.innerHTML = icon
        } else {
          badge.className = 'ec-lang-badge'
          badge.textContent = langAttr.toUpperCase()
        }
        if (titleEl) figcaption.insertBefore(badge, titleEl)
        else figcaption.prepend(badge)
      }
      const toolbar = document.createElement('span')
      toolbar.className = 'code-toolbar ec-code-toolbar'
      toolbar.innerHTML = '<label><span class="hidden sm:inline">theme</span><select data-code-theme-select class="status-select"><option value="github-light-default">light</option><option value="github-dark-default">dark</option></select></label><label><span class="hidden sm:inline">font</span><select data-code-font-select class="status-select"><option value="ui-mono">ui-mono</option><option value="jetbrains">jetbrains</option><option value="sfmono">sfmono</option></select></label>'
      figcaption.appendChild(toolbar)
    })

    syncCodeControls()
    if (!window.__leohuynhCodeControlsBound) {
      window.__leohuynhCodeControlsBound = true
      document.addEventListener('change', (event) => {
        const target = event.target
        if (!(target instanceof HTMLSelectElement)) return
        if (target.matches('[data-code-theme-select]')) {
          localStorage.setItem('leohuynh:code-theme', target.value)
          syncCodeControls()
        }
        if (target.matches('[data-code-font-select]')) {
          localStorage.setItem('leohuynh:code-font', target.value)
          syncCodeControls()
        }
      })
    }

    if (!window.__leohuynhVersionMenuBound) {
      window.__leohuynhVersionMenuBound = true
      const closeVersionMenus = () => {
        document.querySelectorAll('[data-version-popover]').forEach((p) => {
          p.hidden = true
        })
        document.querySelectorAll('[data-version-trigger]').forEach((t) => {
          t.setAttribute('aria-expanded', 'false')
        })
      }
      document.addEventListener('click', (event) => {
        const trigger = event.target.closest('[data-version-trigger]')
        if (trigger) {
          const menu = trigger.closest('[data-version-menu]')
          const popover = menu && menu.querySelector('[data-version-popover]')
          const willOpen = popover && popover.hidden
          closeVersionMenus()
          if (willOpen) {
            popover.hidden = false
            trigger.setAttribute('aria-expanded', 'true')
          }
          return
        }
        // a menu item navigates natively; just close the popover
        if (event.target.closest('[data-version-item]')) {
          closeVersionMenus()
          return
        }
        if (!event.target.closest('[data-version-popover]')) closeVersionMenus()
      })
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeVersionMenus()
      })
    }

    document.querySelectorAll('.studio-shell').forEach((shell) => {
      const toggle = shell.querySelector('[data-toggle-rail]')
      const saved = root.dataset.rail || localStorage.getItem('leohuynh:right-rail') || 'visible'
      const setRail = (state) => {
        shell.dataset.rail = state
        root.dataset.rail = state
        if (toggle) {
          toggle.textContent = state === 'hidden' ? 'show right rail' : 'hide right rail'
          toggle.setAttribute('aria-expanded', String(state !== 'hidden'))
        }
        localStorage.setItem('leohuynh:right-rail', state)
      }
      setRail(saved)
      if (toggle && !toggle.dataset.bound) {
        toggle.dataset.bound = 'true'
        toggle.addEventListener('click', () => {
          setRail((root.dataset.rail || shell.dataset.rail) === 'hidden' ? 'visible' : 'hidden')
        })
      }

      shell.querySelectorAll('[data-folder-toggle]').forEach((button) => {
        if (button.dataset.bound) return
        button.dataset.bound = 'true'
        const id = button.getAttribute('data-folder-toggle')
        const children = shell.querySelector(`[data-folder-children="${id}"]`)
        const caret = button.querySelector('.explorer-caret')
        const storageKey = `leohuynh:folder:${id}`
        const setOpen = (open) => {
          button.setAttribute('aria-expanded', String(open))
          if (children) children.hidden = !open
          if (caret) caret.style.transform = open ? 'rotate(0deg)' : 'rotate(-90deg)'
        }
        const saved = localStorage.getItem(storageKey)
        const defaultOpen = button.getAttribute('data-folder-default') !== 'closed'
        setOpen(saved !== null ? saved !== 'false' : defaultOpen)
        button.addEventListener('click', () => {
          const next = button.getAttribute('aria-expanded') !== 'true'
          localStorage.setItem(storageKey, String(next))
          setOpen(next)
        })
      })

      const timeEl = shell.querySelector('[data-local-time]')
      const diffEl = shell.querySelector('[data-local-time-diff]')
      const updateTime = () => {
        if (!timeEl) return
        const date = new Date()
        const hanoiOffset = -420
        const visitorOffset = date.getTimezoneOffset()
        const hoursDiff = (visitorOffset - hanoiOffset) / 60
        const diff = hoursDiff === 0 ? 'same time' : hoursDiff > 0 ? `${hoursDiff}h ahead` : `${Math.abs(hoursDiff)}h behind`
        timeEl.textContent = new Intl.DateTimeFormat('en-US', {
          timeZone: 'Asia/Ho_Chi_Minh',
          hour: '2-digit',
          minute: '2-digit',
          hour12: true,
          timeZoneName: 'short',
        }).format(date)
        if (diffEl) diffEl.textContent = `- ${diff}`
      }
      updateTime()
      if (!shell.dataset.timeBound) {
        shell.dataset.timeBound = 'true'
        setInterval(updateTime, 30_000)
      }

      const commitLink = shell.querySelector('[data-commit-time]')
      const commitAgoEl = shell.querySelector('[data-commit-ago]')
      const updateCommitAgo = () => {
        if (!commitLink || !commitAgoEl) return
        const date = new Date(commitLink.getAttribute('data-commit-time') || '')
        if (Number.isNaN(date.getTime())) return
        const seconds = Math.floor((Date.now() - date.getTime()) / 1000)
        const rtf = new Intl.RelativeTimeFormat('en', { numeric: 'auto' })
        let value
        let unit
        if (seconds < 60) {
          value = seconds
          unit = 'second'
        } else if (seconds < 3600) {
          value = Math.floor(seconds / 60)
          unit = 'minute'
        } else if (seconds < 86400) {
          value = Math.floor(seconds / 3600)
          unit = 'hour'
        } else {
          value = Math.floor(seconds / 86400)
          unit = 'day'
        }
        commitAgoEl.textContent = `· ${rtf.format(-value, unit)}`
      }
      updateCommitAgo()
      if (!shell.dataset.commitBound) {
        shell.dataset.commitBound = 'true'
        setInterval(updateCommitAgo, 60_000)
      }
    })
  }

  initStudioShell()
  document.addEventListener('astro:page-load', initStudioShell)
</script>
