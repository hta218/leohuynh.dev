---
import { getCollection } from 'astro:content'
import { getDotfilesTree } from '~/lib/dotfiles'
import { SITE } from '~/lib/site'
import RuntimeRail from './runtime-rail/RuntimeRail.astro'
import { buildExplorerTree } from './studio-shell/lib/explorer-tree'
import { getCommitInfo } from './studio-shell/lib/meta'
import {
  getReadmeTab,
  getSeedTabs,
  resolveCurrentTab,
} from './studio-shell/lib/tabs'
import Sidebar from './studio-shell/Sidebar.astro'
import StatusBar from './studio-shell/StatusBar.astro'
import TabBar from './studio-shell/TabBar.astro'

interface Props {
  /** path used to highlight the active explorer entry, e.g. "/blog" */
  active?: string
  /** breadcrumb shown above the main content, e.g. "~/leohuynh.dev/main" */
  crumb?: string
}

const { active, crumb = '~/leohuynh.dev/main' } = Astro.props
const currentPath = (active ?? Astro.url.pathname.replace(/\/$/, '')) || '/'
const isPublished = (d: { data: { draft?: boolean } }) => d.data.draft !== true

const [posts, snippets] = await Promise.all([
  getCollection('blog', isPublished),
  getCollection('snippets', isPublished),
])
const latestPost = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)[0]
const latestSnippet = snippets.sort((a, b) => b.id.localeCompare(a.id))[0]

const {
  items: explorerItems,
  postsIndex,
  snippetsIndex,
} = buildExplorerTree({
  latestPostId: latestPost?.id,
  latestSnippetId: latestSnippet?.id,
  statsUrl: SITE.analytics.umamiShareUrl,
})

const rawDotfilesTree = await getDotfilesTree()
// Hoist the root README to the top of the group so it reads like a landing entry.
const dotfilesTree = [...rawDotfilesTree].sort((a, b) => {
  if (a.path === 'README.md') return -1
  if (b.path === 'README.md') return 1
  return 0
})
const activeDotfile =
  currentPath === '/dotfiles'
    ? ''
    : currentPath.startsWith('/dotfiles/')
      ? decodeURIComponent(currentPath.slice('/dotfiles/'.length))
      : undefined

const shellId = `studio-${Math.random().toString(36).slice(2)}`

// The tab bar behaves like IDE editor tabs: it starts with just the README and
// grows as the visitor navigates (managed client-side). Here we only compute the
// descriptors that seed the bar on the server: README (always pinned) + current.
const readmeTab = getReadmeTab(explorerItems)
const currentTab = resolveCurrentTab(currentPath, {
  items: explorerItems,
  postsIndex,
  snippetsIndex,
})
const seedTabs = getSeedTabs(readmeTab, currentTab)

const { lastCommit, lastCommitDate, lastCommitUrl } = getCommitInfo()
---

<div id={shellId} class="studio-shell grid h-screen grid-rows-[1fr_32px] overflow-hidden bg-bg" data-rail="visible">
  <div class="studio-workspace grid min-h-0 grid-cols-1 overflow-hidden lg:grid-cols-[260px_minmax(0,1fr)_360px]">
    <Sidebar
      explorerItems={explorerItems}
      currentPath={currentPath}
      dotfilesTree={dotfilesTree}
      activeDotfile={activeDotfile}
    />

    <main class="flex min-h-0 min-w-0 flex-col overflow-hidden bg-panel [background-image:linear-gradient(90deg,rgba(15,23,42,0.03)_1px,transparent_1px)] [background-size:64px_64px]">
      <TabBar seedTabs={seedTabs} currentTab={currentTab} />

      <div class="thin-scrollbar min-h-0 flex-1 overflow-y-auto px-[clamp(22px,5vw,78px)] pt-9.5 pb-17.5">
        <div class="mb-4.5 font-mono text-xs text-slate-500">{crumb}</div>
        <slot />
      </div>
    </main>

    <RuntimeRail />
  </div>

  <StatusBar
    lastCommit={lastCommit}
    lastCommitDate={lastCommitDate}
    lastCommitUrl={lastCommitUrl}
  />
</div>

<script>
  import './studio-shell/client/boot'
</script>
