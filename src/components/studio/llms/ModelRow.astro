---
import {
  formatApproxUsd,
  formatTokens,
  INLINE_MODEL_ICONS,
  modelBrandIcon,
  shortModelName,
} from '~/lib/runtime/llm-format'
import type { TokenBurnModelSlice } from '~/types/integrations'

interface Props {
  model: TokenBurnModelSlice
  rank: number
  maxTokens: number
  totalTokens: number
}

const { model, rank, maxTokens, totalTokens } = Astro.props

const brand = modelBrandIcon(model.model)
const icon =
  brand.type === 'cdn'
    ? { cdn: `https://cdn.simpleicons.org/${brand.slug}` }
    : { svg: INLINE_MODEL_ICONS[brand.key] ?? '' }

const barWidth = Math.max(2, (model.tokens / maxTokens) * 100)
const pct = (model.tokens / totalTokens) * 100
const share = pct >= 1 ? `${Math.round(pct)}%` : '<1%'
const cost = model.cost > 0 ? formatApproxUsd(model.cost) : '—'
---

<div class="flex items-center gap-3 border-b border-line px-4 py-2.5 font-mono text-[12px] tabular-nums transition-colors last:border-b-0 hover:bg-panel2">
  <span class="w-5 shrink-0 text-[11px] text-muted">
    {String(rank).padStart(2, '0')}
  </span>
  {
    icon.cdn ? (
      <img src={icon.cdn} alt="" loading="lazy" class="h-4 w-4 shrink-0" />
    ) : (
      <span
        class="inline-flex h-4 w-4 shrink-0 items-center justify-center text-ink"
        set:html={icon.svg}
      />
    )
  }
  <span class="min-w-0 flex-1 truncate text-[13px] text-ink sm:flex-none sm:w-60">
    {shortModelName(model.model)}
  </span>
  <span class="hidden h-1.5 flex-1 overflow-hidden rounded-full bg-line/60 sm:block">
    <span
      class:list={['block h-full rounded-full', rank === 1 ? 'bg-ink' : 'bg-ink/55']}
      style={`width:${barWidth}%`}></span>
  </span>
  <span class="w-18 shrink-0 text-right text-ink">{formatTokens(model.tokens)}</span>
  <span class="w-10 shrink-0 text-right text-muted">{share}</span>
  <span class="w-20 shrink-0 text-right text-muted">{cost}</span>
</div>
