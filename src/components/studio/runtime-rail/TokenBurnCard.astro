<div class="rounded-2xl border border-line bg-white p-3.5">
  <div class="mb-3 flex items-center justify-between gap-3">
    <h3 class="font-mono text-[11px] uppercase tracking-[0.08em] text-muted">
      token burn
    </h3>
    <span data-tb-meta class="font-mono text-[10px] uppercase tracking-[0.08em] text-muted">
      all-time
    </span>
  </div>
  <a href="/llms" class="group block rounded-xl border border-line bg-[#fbfdff] p-2.5 no-underline transition-colors hover:border-ink/30 hover:bg-white">
    <span class="flex items-baseline justify-between gap-1.5">
      <span class="flex items-baseline gap-1.5">
        <b data-tb-alltime-tokens class="text-xl leading-tight text-ink tabular-nums">—</b>
        <span class="font-mono text-[10px] text-muted">tokens</span>
      </span>
      <span class="font-mono text-[10px] text-muted opacity-0 transition-opacity group-hover:opacity-100">llms.json ↗</span>
    </span>
    <span data-tb-alltime-sub class="mt-1 block font-mono text-[10px] text-muted">loading…</span>
  </a>
  <div class="mt-2 grid gap-1.5">
    <div class="flex items-baseline justify-between gap-3 border-b border-dashed border-line/80 py-1">
      <span class="font-mono text-[10px] uppercase tracking-[0.06em] text-muted">today</span>
      <strong data-tb-today class="font-mono text-[12px]">—</strong>
    </div>
  </div>
  <div class="mt-2">
    <h4 class="mb-2 font-mono text-[10px] uppercase tracking-[0.08em] text-muted">
      by models
    </h4>
    <div data-tb-models class="grid gap-1.5">
      <div class="flex items-center justify-between gap-3 py-1">
        <span class="inline-block h-3 w-20 rounded-full bg-line/70 animate-pulse"></span>
        <span class="inline-block h-3 w-16 rounded-full bg-line/70 animate-pulse"></span>
      </div>
    </div>
  </div>
</div>
