---
import { ClientRouter } from 'astro:transitions'
import { SITE } from '~/lib/site'
import '~/styles/global.css'

interface Props {
  title?: string
  description?: string
  /** Override canonical (e.g. post frontmatter `canonicalUrl`). */
  canonicalUrl?: string
  /** Page-specific OG/Twitter image (absolute or site-relative). */
  ogImage?: string
  /** `website` (default) or `article` for post/snippet detail pages. */
  ogType?: 'website' | 'article'
  /** ISO published date, emitted as `article:published_time`. */
  publishedTime?: string
  /** ISO last-modified date, emitted as `article:modified_time`. */
  modifiedTime?: string
  /** Page content language, drives `<html lang>` and `og:locale`. */
  lang?: 'en' | 'vi'
  /** `hreflang` alternates for pages with translated counterparts. */
  alternates?: { hreflang: string; href: string }[]
  /** Set on thin/low-value pages (e.g. single-item tag pages) to keep them out of search results. */
  noindex?: boolean
}

const {
  title,
  description = SITE.description,
  canonicalUrl,
  ogImage,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  lang = 'en',
  alternates = [],
  noindex = false,
} = Astro.props

const pageTitle = title ? `${title} — ${SITE.author}` : SITE.title
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, SITE.siteUrl).href
const image = new URL(ogImage ?? SITE.socialBanner, SITE.siteUrl).href
const rssTitle = `${SITE.title} RSS feed`
const ogLocale = lang === 'vi' ? 'vi-VN' : SITE.locale
const umamiWebsiteId = (
  import.meta.env.PUBLIC_UMAMI_WEBSITE_ID || process.env.PUBLIC_UMAMI_WEBSITE_ID
)?.trim()
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />
    {
      alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
      ))
    }
    <link rel="icon" type="image/svg+xml" href="/static/twemoji/2328-fe0f.svg" />
    <link rel="apple-touch-icon" href="/static/images/avatar.jpg" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <script is:inline>
      ;(() => {
        const apply = (root) => {
          root.dataset.theme = 'github-light-default'
          root.dataset.codeFont = 'ui-mono'
          root.dataset.rail = localStorage.getItem('leohuynh:right-rail') || 'visible'
        }
        // Run before first paint so the right rail never flashes visible→hidden.
        apply(document.documentElement)
        // Carry the persisted state onto the incoming document before the
        // view-transition swap paints, so SPA navigations don't flicker either.
        document.addEventListener('astro:before-swap', (event) => {
          apply(event.newDocument.documentElement)
        })
      })()
    </script>

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.headerTitle} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={image} />
    {publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={rssTitle}
      href={new URL('/feed.xml', SITE.siteUrl).href}
    />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    {
      umamiWebsiteId && (
        <script
          is:inline
          defer
          src="https://analytics.leohuynh.dev/script.js"
          data-website-id={umamiWebsiteId}
          data-performance="true"
        />
      )
    }
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
