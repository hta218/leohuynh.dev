---
import { getCollection, render } from 'astro:content'
import JsonLd from '~/components/JsonLd.astro'
import Twemoji from '~/components/mdx/Twemoji.astro'
import StudioShell from '~/components/studio/StudioShell.astro'
import Reactions from '~/components/widgets/Reactions'
import ViewsCounter from '~/components/widgets/ViewsCounter'
import Comments from '~/components/widgets/Comments'
import { getGiscusConfig } from '~/lib/comments'
import { isPublished, tagSlug } from '~/lib/content'
import { articleJsonLd, breadcrumbJsonLd } from '~/lib/seo'
import { SITE } from '~/lib/site'
import BaseLayout from '~/layouts/BaseLayout.astro'

// Slug parity: id = filename (no nested dirs) → `/blog/<slug>` exactly as legacy.
export async function getStaticPaths() {
  const posts = await getCollection('blog', isPublished)
  return posts.map((post) => {
    const primaryId = post.data.translationOf ?? post.id
    // Every language variant of the same post: the primary + anything that
    // points back to it via `translationOf`.
    const translations = posts
      .filter((p) => p.id === primaryId || p.data.translationOf === primaryId)
      .sort((a, b) => a.data.lang.localeCompare(b.data.lang))
    return { params: { slug: post.id }, props: { post, translations } }
  })
}

const { post, translations } = Astro.props
const { Content } = await render(post)
const { title, summary, seoTitle, seoDescription, date, lastmod, tags, images, canonicalUrl, lang } =
  post.data
const metaTitle = seoTitle ?? title
const metaDescription = seoDescription ?? summary
const ogImage = Array.isArray(images) ? images[0] : images
const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
const giscusConfig = getGiscusConfig()

const canonical = canonicalUrl ?? new URL(`/blog/${post.id}`, SITE.siteUrl).href
const jsonLd = [
  articleJsonLd({
    title,
    description: metaDescription,
    url: canonical,
    image: new URL(ogImage ?? SITE.socialBanner, SITE.siteUrl).href,
    datePublished: date.toISOString(),
    dateModified: lastmod ? new Date(lastmod).toISOString() : undefined,
    keywords: tags,
    inLanguage: lang,
  }),
  breadcrumbJsonLd([
    { name: 'Home', url: SITE.siteUrl },
    { name: 'Log', url: `${SITE.siteUrl}/blog` },
    { name: title, url: canonical },
  ]),
]

// hreflang alternates so search engines know these pages are translations
// of each other, not unrelated/duplicate content. `x-default` falls back to
// the primary (non-translated) post.
const alternates =
  translations.length > 1
    ? [
        ...translations.map((t) => ({
          hreflang: t.data.lang,
          href: new URL(`/blog/${t.id}`, SITE.siteUrl).href,
        })),
        {
          hreflang: 'x-default',
          href: new URL(
            `/blog/${translations.find((t) => !t.data.translationOf)?.id ?? post.id}`,
            SITE.siteUrl,
          ).href,
        },
      ]
    : []
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  ogType="article"
  publishedTime={date.toISOString()}
  modifiedTime={lastmod ? new Date(lastmod).toISOString() : undefined}
  lang={lang}
  alternates={alternates}
>
  <Fragment slot="head">
    {jsonLd.map((data) => <JsonLd data={data} />)}
  </Fragment>
  <StudioShell active={`/blog/${post.id}`} crumb={`~/leohuynh.dev/logs/${post.id}`}>
    <article class="prose">
      <h1>{title}</h1>
      <div class="mb-8 flex flex-wrap items-center gap-3 font-mono text-xs text-muted not-prose">
        <time datetime={date.toISOString()}>{dateFmt.format(date)}</time>
        {
          lastmod && (
            <span>· updated {dateFmt.format(new Date(lastmod))}</span>
          )
        }
        <span>·</span>
        <ViewsCounter type="blog" slug={post.id} client:load />
        {
          tags.map((tag) => (
            <a
              href={`/topics/${tagSlug(tag)}`}
              class="rounded-full border border-line px-2 py-0.5 text-code-blue no-underline"
            >
              #{tag}
            </a>
          ))
        }
        {
          translations.length > 1 && (
            <span class="ml-auto flex items-center gap-0.5 rounded-full border border-line bg-panel2 p-0.5">
              {translations.map((t) =>
                t.id === post.id ? (
                  <span class="rounded-full bg-ink px-2.5 py-1 uppercase tracking-wide text-bg">
                    {t.data.lang}
                  </span>
                ) : (
                  <a
                    href={`/blog/${t.id}`}
                    class="rounded-full px-2.5 py-1 uppercase tracking-wide text-muted no-underline transition-colors hover:text-ink"
                  >
                    {t.data.lang}
                  </a>
                ),
              )}
            </span>
          )
        }
      </div>
      <Content components={{ Twemoji }} />
      <div class="mt-12 flex flex-col gap-3 border-t border-line pt-6 not-prose">
        <span class="font-mono text-[11px] uppercase tracking-[0.08em] text-muted">
          react to this post
        </span>
        <Reactions type="blog" slug={post.id} client:visible />
      </div>
      {giscusConfig && <Comments config={giscusConfig} client:only="react" />}
    </article>
  </StudioShell>
</BaseLayout>
