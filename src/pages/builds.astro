---
import ProjectCard from '~/components/builds/ProjectCard.astro'
import PageHeader from '~/components/PageHeader.astro'
import StudioShell from '~/components/studio/StudioShell.astro'
import BaseLayout from '~/layouts/BaseLayout.astro'
import { BRAND_ICONS } from '~/lib/brand-icons'
import { PROJECTS } from '~/lib/projects'

const projects = PROJECTS
const work = projects.filter((p) => p.type === 'work')
const self = projects.filter((p) => p.type === 'self')

// Languages the GitHub API may report for these repos — serialized for the
// client script so the hydrated "Language" cell can swap in a brand icon.
const LANGUAGE_ICONS: Record<string, string> = Object.fromEntries(
  [
    'TypeScript',
    'JavaScript',
    'Shell',
    'Liquid',
    'Python',
    'Java',
    'CSS',
    'HTML',
    'MDX',
  ]
    .map((lang) => [lang, BRAND_ICONS[lang]])
    .filter(([, icon]) => Boolean(icon)),
)

const groups = [
  { title: 'Work', items: work, note: 'commercial / professional' },
  { title: 'Side projects', items: self, note: 'open-source / personal' },
]
---

<BaseLayout title="Builds" description="Things I've built — commercial work and personal open-source projects.">
  <StudioShell active="/builds" crumb="~/leohuynh.dev/builds/">
    <PageHeader
      title="Builds"
      description="Open-source side projects, commercial work, and practical tools I’ve built with teammates or shipped on my own."
    />

    {
      groups.map((group) => (
        <section class="mb-12">
          <div class="mb-5 flex items-end justify-between">
            <h2 class="m-0 text-[22px] tracking-[-0.04em]">{group.title}</h2>
            <span class="font-mono text-xs text-muted">{group.note}</span>
          </div>
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            {group.items.map((p) => (
              <ProjectCard project={p} />
            ))}
          </div>
        </section>
      ))
    }
  </StudioShell>
</BaseLayout>

<script is:inline type="application/json" id="project-language-icons" set:html={JSON.stringify(LANGUAGE_ICONS)}></script>

<script>
  import '~/components/builds/hydrate'
</script>
