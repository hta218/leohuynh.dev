---
import { getCollection, render } from 'astro:content'
import JsonLd from '~/components/JsonLd.astro'
import Twemoji from '~/components/mdx/Twemoji.astro'
import StudioShell from '~/components/studio/StudioShell.astro'
import Reactions from '~/components/widgets/Reactions'
import ViewsCounter from '~/components/widgets/ViewsCounter'
import Comments from '~/components/widgets/Comments'
import { getGiscusConfig } from '~/lib/comments'
import { isPublished, tagSlug } from '~/lib/content'
import { articleJsonLd, breadcrumbJsonLd } from '~/lib/seo'
import { SITE } from '~/lib/site'
import BaseLayout from '~/layouts/BaseLayout.astro'

// Slug parity: id = filename → `/snippets/<slug>` exactly as legacy.
export async function getStaticPaths() {
  const snippets = await getCollection('snippets', isPublished)
  return snippets.map((snippet) => ({
    params: { slug: snippet.id },
    props: { snippet },
  }))
}

const { snippet } = Astro.props
const { Content } = await render(snippet)
const { title, heading, summary, seoTitle, seoDescription, date, lastmod, tags, images, canonicalUrl } =
  snippet.data
const metaTitle = seoTitle ?? title
const metaDescription = seoDescription ?? summary
const ogImage = Array.isArray(images) ? images[0] : images
const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
const giscusConfig = getGiscusConfig()

const canonical = canonicalUrl ?? new URL(`/gists/${snippet.id}`, SITE.siteUrl).href
const jsonLd = [
  articleJsonLd({
    title: heading,
    description: metaDescription,
    url: canonical,
    image: new URL(ogImage ?? SITE.socialBanner, SITE.siteUrl).href,
    datePublished: date.toISOString(),
    dateModified: lastmod ? new Date(lastmod).toISOString() : undefined,
    keywords: tags,
    inLanguage: 'en',
  }),
  breadcrumbJsonLd([
    { name: 'Home', url: SITE.siteUrl },
    { name: 'Gists', url: `${SITE.siteUrl}/gists` },
    { name: heading, url: canonical },
  ]),
]
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  ogType="article"
  publishedTime={date.toISOString()}
  modifiedTime={lastmod ? new Date(lastmod).toISOString() : undefined}
>
  <Fragment slot="head">
    {jsonLd.map((data) => <JsonLd data={data} />)}
  </Fragment>
  <StudioShell active={`/gists/${snippet.id}`} crumb={`~/leohuynh.dev/gists/${snippet.id}`}>
    <article class="prose">
      <h1>{heading}</h1>
      <div class="mb-8 flex flex-wrap items-center gap-3 font-mono text-xs text-muted not-prose">
        <time datetime={date.toISOString()}>{dateFmt.format(date)}</time>
        <span>·</span>
        <ViewsCounter type="snippet" slug={snippet.id} client:load />
        {
          tags.map((tag) => (
            <a
              href={`/topics/${tagSlug(tag)}`}
              class="rounded-full border border-line px-2 py-0.5 text-code-blue no-underline"
            >
              #{tag}
            </a>
          ))
        }
      </div>
      <Content components={{ Twemoji }} />
      <div class="mt-12 flex flex-col gap-3 border-t border-line pt-6 not-prose">
        <span class="font-mono text-[11px] uppercase tracking-[0.08em] text-muted">
          react to this snippet
        </span>
        <Reactions type="snippet" slug={snippet.id} client:visible />
      </div>
      {giscusConfig && <Comments config={giscusConfig} client:only="react" />}
    </article>
  </StudioShell>
</BaseLayout>
