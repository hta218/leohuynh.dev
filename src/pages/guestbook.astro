---
import GuestbookWall from '~/components/guestbook/GuestbookWall'
import PageHeader from '~/components/PageHeader.astro'
import StudioShell from '~/components/studio/StudioShell.astro'
import BaseLayout from '~/layouts/BaseLayout.astro'
import { SESSION_COOKIE } from '~/lib/github-oauth'
import {
  getGuestbookCurrentUser,
  isGuestbookAdmin,
} from '~/lib/guestbook/config'

export const prerender = false

// Keep SSR only for the cheap cookie-based session/admin detection. The entries
// query (Supabase-backed) is intentionally NOT awaited here so the document
// paints without blocking on it; `GuestbookWall` loads the first page
// client-side via GET /api/guestbook, which reads the same session cookie.
const nowSeconds = Math.floor(Date.now() / 1000)
const currentUser = getGuestbookCurrentUser(
  Astro.cookies.get(SESSION_COOKIE)?.value,
  nowSeconds,
)
const isAdmin = isGuestbookAdmin(currentUser?.login)
---

<BaseLayout
  title="Guestbook"
  description="Sign in with GitHub and leave a small trace on the wall."
  noindex={true}
>
  <StudioShell active="/guestbook" crumb="~/leohuynh.dev/guestbook/">
    <PageHeader
      title="Guestbook"
      description="Leave a small trace on the wall."
    />

    <GuestbookWall
      client:load
      currentUser={currentUser}
      isAdmin={isAdmin}
      initialEntries={[]}
      initialNextCursor={null}
      deferInitialLoad={true}
    />
  </StudioShell>
</BaseLayout>
