---
import { getCollection } from 'astro:content'
import { readFileSync } from 'node:fs'
import { glob } from 'tinyglobby'
import JsonLd from '~/components/JsonLd.astro'
import Twemoji from '~/components/mdx/Twemoji.astro'
import StudioShell from '~/components/studio/StudioShell.astro'
import BuildLog from '~/components/widgets/BuildLog'
import BaseLayout from '~/layouts/BaseLayout.astro'
import { siteJsonLd } from '~/lib/seo'

const isPublished = (d: { data: { draft?: boolean } }) => d.data.draft !== true

const posts = (await getCollection('blog', isPublished))
  .filter((p) => !p.data.translationOf)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
const latest = posts.slice(0, 3)

const dateFmt = new Intl.DateTimeFormat('en-CA') // YYYY-MM-DD

// Build-time codebase stats for the build-log manifest. This page is prerendered, so the glob +
// line count run once per build (not per request). Covers source + content, skipping generated
// dirs. `loc` is a true line count; `files` is the matched file count.
const SOURCE_GLOBS = [
  'src/**/*.{ts,tsx,astro,css,mjs}',
  'content/**/*.{md,mdx}',
]
const sourceFiles = await glob(SOURCE_GLOBS, {
  cwd: process.cwd(),
  ignore: ['**/node_modules/**', '**/dist/**', '**/.astro/**'],
})
const loc = sourceFiles.reduce(
  (total, file) => total + readFileSync(file, 'utf8').split('\n').length,
  0,
)
const codebase = {
  repo: 'hta218/leohuynh.dev',
  loc,
  files: sourceFiles.length,
  stack: ['astro', 'bun', 'tailwind', 'typescript'],
}
---

<BaseLayout>
  <Fragment slot="head">
    {siteJsonLd().map((data) => <JsonLd data={data} />)}
  </Fragment>
  <StudioShell active="/" crumb="~/leohuynh.dev/main">
    <!-- hero -->
    <div class="grid items-end gap-6 border-b border-line pb-9">
      <div>
        <h1
          class="m-0 max-w-200 text-[clamp(40px,6vw,74px)] leading-[0.96] tracking-[-0.07em]"
        >
          Howdy, fellow! <Twemoji emoji="waving-hand" size="base" className="twemoji-heading" />
        </h1>
        <p class="mt-5 max-w-175 text-lg leading-relaxed text-muted">
          I'm Tuan Anh Huynh (aliased Leo at work) — a learner, builder, and freedom
          seeker in Hanoi <Twemoji emoji="flag-vietnam" size="base" />.
          <br />
          I'm building Weaverse Hydrogen Studio, a platform to design and ship
          Shopify Hydrogen storefronts. I write here about everything I learn along
          the way — from software engineering to life lessons, and all the bits in
          between.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          {
            ['writer', 'builder', 'shopify hydrogen', 'typescript', 'ai workflows'].map((b) => (
              <span class="rounded-full border border-line bg-white px-2.5 py-2 font-mono text-xs">
                {b}
              </span>
            ))
          }
        </div>
      </div>
    </div>

    <!-- latest writing -->
    <div class="border-b border-line py-8.5">
      <div class="mb-4 flex items-end justify-between">
        <h2 class="m-0 text-[26px] tracking-tighter">latest writing</h2>
        <span class="font-mono text-xs text-muted">content/blog/*.mdx</span>
      </div>
      {
        latest.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="grid grid-cols-1 items-start gap-4.5 border-t border-line py-4.5 no-underline first-of-type:border-t-0 md:grid-cols-[92px_1fr_auto]"
          >
            <time class="font-mono text-xs text-muted">{dateFmt.format(post.data.date)}</time>
            <div>
              <h3 class="mb-1.75 text-[23px] tracking-[-0.04em] text-ink">{post.data.title}</h3>
              <p class="m-0 leading-snug text-muted">{post.data.summary}</p>
            </div>
            {post.data.tags[0] && (
              <span class="rounded-full border border-line px-1.75 py-1.25 font-mono text-[11px] text-code-blue">
                {post.data.tags[0]}
              </span>
            )}
          </a>
        ))
      }
    </div>

    <!-- build log -->
    <div class="py-8.5">
      <div class="mb-4 flex items-end justify-between">
        <h2 class="m-0 text-[26px] tracking-tighter">build log</h2>
        <span class="font-mono text-xs text-muted">api/site-stats.json</span>
      </div>
      <BuildLog
        client:idle
        site="leohuynh.dev"
        description="documenting the work, one note at a time"
        repo={codebase.repo}
        loc={codebase.loc}
        files={codebase.files}
        stack={codebase.stack}
      />
    </div>
  </StudioShell>
</BaseLayout>
