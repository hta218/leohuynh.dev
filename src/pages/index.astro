---
import { getCollection } from 'astro:content'
import { readFileSync } from 'node:fs'
import { glob } from 'tinyglobby'
import HugeIcon from '~/components/icons/HugeIcon.astro'
import Twemoji from '~/components/mdx/Twemoji.astro'
import StudioShell from '~/components/studio/StudioShell.astro'
import BuildLog from '~/components/widgets/BuildLog'
import LiveVisitors from '~/components/widgets/LiveVisitors'
import SiteHits from '~/components/widgets/SiteHits'
import BaseLayout from '~/layouts/BaseLayout.astro'

const isPublished = (d: { data: { draft?: boolean } }) => d.data.draft !== true

const posts = (await getCollection('blog', isPublished)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)
const snippets = await getCollection('snippets', isPublished)
const latest = posts.slice(0, 3)

const dateFmt = new Intl.DateTimeFormat('en-CA') // YYYY-MM-DD

// Build-time codebase stats for the build-log manifest. This page is prerendered, so the glob +
// line count run once per build (not per request). Covers source + content, skipping generated
// dirs. `loc` is a true line count; `files` is the matched file count.
const SOURCE_GLOBS = [
  'src/**/*.{ts,tsx,astro,css,mjs}',
  'content/**/*.{md,mdx}',
]
const sourceFiles = await glob(SOURCE_GLOBS, {
  cwd: process.cwd(),
  ignore: ['**/node_modules/**', '**/dist/**', '**/.astro/**'],
})
const loc = sourceFiles.reduce(
  (total, file) => total + readFileSync(file, 'utf8').split('\n').length,
  0,
)
const codebase = {
  repo: 'hta218/leohuynh.dev',
  loc,
  files: sourceFiles.length,
  stack: ['astro', 'bun', 'tailwind', 'typescript'],
}
---

<BaseLayout>
  <StudioShell active="/" crumb="~/leohuynh.dev/main">
    <!-- hero -->
    <div class="grid items-end gap-6 border-b border-line pb-9">
      <div>
        <h1
          class="m-0 max-w-[800px] text-[clamp(40px,6vw,74px)] leading-[0.96] tracking-[-0.07em]"
        >
          Howdy, fellow! <Twemoji emoji="waving-hand" size="base" className="twemoji-heading" />
        </h1>
        <p class="mt-5 max-w-[700px] text-lg leading-relaxed text-muted">
          Tuan Anh Huynh, aliased Leo at work — a learner, builder, and freedom
          seeker in Hanoi, building eCommerce software with JS/TS and Shopify Hydrogen.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          {
            ['writer', 'builder', 'shopify hydrogen', 'typescript', 'ai workflows'].map((b) => (
              <span class="rounded-full border border-line bg-white px-2.5 py-2 font-mono text-xs">
                {b}
              </span>
            ))
          }
        </div>
      </div>

      <div class="grid w-[min(520px,100%)] grid-cols-3 gap-2">
        <div class="rounded-2xl border border-line bg-white p-3">
          <div class="flex items-center justify-between">
            <b class="block text-[28px]">{posts.length + snippets.length}</b>
            <HugeIcon name="markdown" class="text-slate-400" />
          </div>
          <span class="font-mono text-[11px] text-muted">notes</span>
        </div>
        <div class="rounded-2xl border border-line bg-white p-3">
          <div class="flex items-center justify-between">
            <b class="block text-[28px]"><SiteHits client:idle /></b>
            <HugeIcon name="analytics" class="text-slate-400" />
          </div>
          <span class="font-mono text-[11px] text-muted">hits</span>
        </div>
        <div class="rounded-2xl border border-line bg-white p-3">
          <div class="flex items-center justify-between">
            <b class="block text-[28px]"><LiveVisitors client:idle /></b>
            <span class="relative flex h-2.5 w-2.5" title="live visitors">
              <span
                class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-500 opacity-75"
              ></span>
              <span
                class="relative inline-flex h-2.5 w-2.5 rounded-full bg-green-500"
              ></span>
            </span>
          </div>
          <span class="font-mono text-[11px] text-muted">live visitors</span>
        </div>
      </div>
    </div>

    <!-- latest writing -->
    <div class="border-b border-line py-[34px]">
      <div class="mb-4 flex items-end justify-between">
        <h2 class="m-0 text-[26px] tracking-[-0.05em]">latest writing</h2>
        <span class="font-mono text-xs text-muted">content/blog/*.mdx</span>
      </div>
      {
        latest.map((post) => (
          <a
            href={`/log/${post.id}`}
            class="grid grid-cols-1 items-start gap-[18px] border-t border-line py-[18px] no-underline first-of-type:border-t-0 md:grid-cols-[92px_1fr_auto]"
          >
            <time class="font-mono text-xs text-muted">{dateFmt.format(post.data.date)}</time>
            <div>
              <h3 class="mb-[7px] text-[23px] tracking-[-0.04em] text-ink">{post.data.title}</h3>
              <p class="m-0 leading-snug text-muted">{post.data.summary}</p>
            </div>
            {post.data.tags[0] && (
              <span class="rounded-full border border-line px-[7px] py-[5px] font-mono text-[11px] text-code-blue">
                {post.data.tags[0]}
              </span>
            )}
          </a>
        ))
      }
    </div>

    <!-- build log -->
    <div class="py-[34px]">
      <div class="mb-4 flex items-end justify-between">
        <h2 class="m-0 text-[26px] tracking-[-0.05em]">build log</h2>
        <span class="font-mono text-xs text-muted">api/site-stats.json</span>
      </div>
      <BuildLog
        client:idle
        site="leohuynh.dev"
        description="documenting the work, one note at a time"
        repo={codebase.repo}
        loc={codebase.loc}
        files={codebase.files}
        stack={codebase.stack}
      />
    </div>
  </StudioShell>
</BaseLayout>
