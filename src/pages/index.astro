---
import { getCollection } from 'astro:content'
import Twemoji from '~/components/mdx/Twemoji.astro'
import CodeBlock from '~/components/studio/CodeBlock.astro'
import StudioShell from '~/components/studio/StudioShell.astro'
import HugeIcon from '~/components/icons/HugeIcon.astro'
import BaseLayout from '~/layouts/BaseLayout.astro'

const isPublished = (d: { data: { draft?: boolean } }) => d.data.draft !== true

const posts = (await getCollection('blog', isPublished)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)
const snippets = await getCollection('snippets', isPublished)
const latest = posts.slice(0, 3)

const exploreCards = [
  { href: '/snippets', label: 'snippets/', desc: 'reusable code bits', icon: 'code' },
  { href: '/projects', label: 'projects/', desc: 'things I built', icon: 'folder' },
  { href: '/books', label: 'books/', desc: 'what I read', icon: 'book' },
  { href: '/movies', label: 'movies/', desc: 'what I watch', icon: 'file' },
] as const

const dateFmt = new Intl.DateTimeFormat('en-CA') // YYYY-MM-DD
---

<BaseLayout>
  <StudioShell active="/" crumb="~/leohuynh.dev/main">
    <!-- hero -->
    <div class="grid items-end gap-6 border-b border-line pb-9">
      <div>
        <h1
          class="m-0 max-w-[800px] text-[clamp(40px,6vw,74px)] leading-[0.96] tracking-[-0.07em]"
        >
          Howdy, fellow! <Twemoji emoji="waving-hand" size="base" className="twemoji-heading" />
        </h1>
        <p class="mt-5 max-w-[700px] text-lg leading-relaxed text-muted">
          Tuan Anh Huynh, aliased Leo at work — a learner, builder, and freedom
          seeker in Hanoi, building eCommerce software with JS/TS and Shopify Hydrogen.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          {
            ['writer', 'builder', 'shopify hydrogen', 'typescript', 'ai workflows'].map((b) => (
              <span class="rounded-full border border-line bg-white px-2.5 py-2 font-mono text-xs">
                {b}
              </span>
            ))
          }
        </div>
      </div>

      <div class="grid w-[min(520px,100%)] grid-cols-3 gap-2">
        <div class="rounded-2xl border border-line bg-white p-3">
          <div class="flex items-center justify-between">
            <b class="block text-[28px]">{posts.length}</b>
            <HugeIcon name="folder" class="text-slate-400" />
          </div>
          <span class="font-mono text-[11px] text-muted">posts</span>
        </div>
        <div class="rounded-2xl border border-line bg-white p-3">
          <div class="flex items-center justify-between">
            <b class="block text-[28px]">{snippets.length}</b>
            <HugeIcon name="code" class="text-slate-400" />
          </div>
          <span class="font-mono text-[11px] text-muted">snippets</span>
        </div>
        <div class="rounded-2xl border border-line bg-white p-3">
          <div class="flex items-center justify-between">
            <b class="block text-[28px]">—</b>
            <HugeIcon name="analytics" class="text-slate-400" />
          </div>
          <span class="font-mono text-[11px] text-muted">views</span>
        </div>
      </div>
    </div>

    <!-- latest writing -->
    <div class="border-b border-line py-[34px]">
      <div class="mb-4 flex items-end justify-between">
        <h2 class="m-0 text-[26px] tracking-[-0.05em]">latest writing</h2>
        <span class="font-mono text-xs text-muted">content/blog/*.mdx</span>
      </div>
      {
        latest.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="grid grid-cols-1 items-start gap-[18px] border-t border-line py-[18px] no-underline first-of-type:border-t-0 md:grid-cols-[92px_1fr_auto]"
          >
            <time class="font-mono text-xs text-muted">{dateFmt.format(post.data.date)}</time>
            <div>
              <h3 class="mb-[7px] text-[23px] tracking-[-0.04em] text-ink">{post.data.title}</h3>
              <p class="m-0 leading-snug text-muted">{post.data.summary}</p>
            </div>
            {post.data.tags[0] && (
              <span class="rounded-full border border-line px-[7px] py-[5px] font-mono text-[11px] text-code-blue">
                {post.data.tags[0]}
              </span>
            )}
          </a>
        ))
      }
    </div>

    <!-- explore -->
    <div class="border-b border-line py-[34px]">
      <div class="mb-4 flex items-end justify-between">
        <h2 class="m-0 text-[26px] tracking-[-0.05em]">explore</h2>
        <span class="font-mono text-xs text-muted">cd ~/leohuynh.dev</span>
      </div>
      <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
        {
          exploreCards.map((c) => (
            <a
              href={c.href}
              class="rounded-2xl border border-line bg-white p-4 no-underline transition-shadow hover:shadow-[4px_4px_0_var(--color-line)]"
            >
              <div class="flex items-center gap-2 font-mono text-sm text-slate-900">
                <HugeIcon name={c.icon} class="text-slate-500" /> {c.label}
              </div>
              <div class="mt-1 text-[13px] text-muted">{c.desc}</div>
            </a>
          ))
        }
      </div>
    </div>

    <!-- build log -->
    <div class="py-[34px]">
      <div class="mb-4 flex items-end justify-between">
        <h2 class="m-0 text-[26px] tracking-[-0.05em]">build log</h2>
        <span class="font-mono text-xs text-muted">api/activity.json</span>
      </div>
      <CodeBlock title="activity.json"><span class="text-[#94a3b8]">// generated at build time from content collections</span>
{`{`}
  <span class="text-[#93c5fd]">"site"</span>: {`{`} <span class="text-[#93c5fd]">"posts"</span>: <span class="text-[#86efac]">{posts.length}</span>, <span class="text-[#93c5fd]">"snippets"</span>: <span class="text-[#86efac]">{snippets.length}</span> {`}`},
  <span class="text-[#93c5fd]">"stack"</span>: [<span class="text-[#86efac]">"astro"</span>, <span class="text-[#86efac]">"bun"</span>, <span class="text-[#86efac]">"tailwind"</span>, <span class="text-[#86efac]">"typescript"</span>],
  <span class="text-[#93c5fd]">"status"</span>: <span class="text-[#86efac]">"documenting the work, one note at a time"</span>
{`}`}</CodeBlock>
    </div>
  </StudioShell>
</BaseLayout>
