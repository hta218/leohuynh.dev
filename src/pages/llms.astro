---
import PageHeader from '~/components/PageHeader.astro'
import StudioShell from '~/components/studio/StudioShell.astro'
import BaseLayout from '~/layouts/BaseLayout.astro'

// Keep the route static/cheap. Full token-burn telemetry is loaded after first
// paint from `/api/token-burn.json?view=full`, so client navigation no longer
// waits on the private GitHub summary fetch during document render.
export const prerender = true

const HERO_META = [
  { key: 'spend', value: 'loading…', label: 'spend' },
  { key: 'sessions', value: 'loading…', label: 'sessions' },
  { key: 'machines', value: 'loading…', label: 'machines' },
]

const WINDOWS = [
  { key: 'today', label: 'today' },
  { key: 'last7Days', label: 'last 7 days' },
  { key: 'last30Days', label: 'last 30 days' },
]
---

<BaseLayout
  title="LLM token burn"
  description="How many tokens I burn coding with AI — all-time spend, sessions, a daily burn chart, and the breakdown by model, read live from my own private usage telemetry."
>
  <StudioShell active="/llms" crumb="~/leohuynh.dev/llms/">
    <div data-llms-page>
      <PageHeader
        title="LLM token burn"
        description="Every token I've burned pair-coding with AI agents. Pulled live from my own private usage telemetry — all-time totals, a daily burn chart, and where the tokens actually go, model by model."
      />

      <p
        data-llms-error
        hidden
        class="mb-8 rounded-2xl border border-line bg-white p-4 font-mono text-[13px] text-muted"
      >
        telemetry is unavailable right now.
      </p>

      {/* ── Hero: all-time headline ────────────────────────────── */}
      <section class="llms-sec mb-8" style="animation-delay:40ms">
        <div class="relative overflow-hidden rounded-2xl border border-ink bg-white p-6 shadow-[5px_5px_0_var(--color-ink)] sm:p-8">
          <span
            class="pointer-events-none absolute inset-0 bg-[linear-gradient(90deg,rgba(15,23,42,0.045)_1px,transparent_1px)] bg-size-[26px_100%] opacity-70"
            aria-hidden="true"></span>
          <span
            class="pointer-events-none absolute top-1/2 right-4 hidden -translate-y-1/2 -rotate-6 font-mono text-[180px] leading-none font-bold text-ink/4 select-none sm:block"
            aria-hidden="true">{'{ }'}</span>
          <div class="relative">
            <span class="flex items-center gap-2 font-mono text-[11px] tracking-widest text-muted uppercase">
              <span class="inline-block h-1.5 w-1.5 rounded-full bg-ink"></span>
              tokens burned · all-time
            </span>
            <p
              data-llms-all-time-tokens
              class="m-0 mt-3 text-[clamp(34px,6.4vw,66px)] leading-[0.92] font-semibold tracking-tighter text-ink tabular-nums"
            >
              loading…
            </p>
            <dl class="mt-6 grid max-w-md grid-cols-3 gap-px overflow-hidden rounded-xl border border-line bg-line">
              {
                HERO_META.map((m) => (
                  <div class="bg-white px-4 py-3">
                    <dt class="m-0 font-mono text-[10px] tracking-[0.08em] text-muted uppercase">
                      {m.label}
                    </dt>
                    <dd
                      data-llms-hero-meta={m.key}
                      class="m-0 mt-1 text-[19px] tracking-[-0.03em] text-ink tabular-nums"
                    >
                      {m.value}
                    </dd>
                  </div>
                ))
              }
            </dl>
          </div>
        </div>
      </section>

      {/* ── Recent windows ─────────────────────────────────────── */}
      <section class="llms-sec mb-12" style="animation-delay:100ms">
        <div class="mb-3 flex items-center gap-3">
          <h2 class="m-0 font-mono text-[13px] tracking-widest text-muted uppercase">
            recent
          </h2>
          <span class="h-px flex-1 bg-line" aria-hidden="true"></span>
        </div>
        <div class="grid grid-cols-3 gap-px overflow-hidden rounded-2xl border border-line bg-line">
          {
            WINDOWS.map(({ key, label }) => (
              <div class="bg-white p-4">
                <span class="font-mono text-[10px] tracking-[0.08em] text-muted uppercase">
                  {label}
                </span>
                <p
                  data-llms-window-value={key}
                  class="m-0 mt-2 text-[clamp(18px,2.4vw,22px)] tracking-[-0.03em] text-ink tabular-nums"
                >
                  loading…
                </p>
                <p
                  data-llms-window-meta={key}
                  class="m-0 mt-1 font-mono text-[11px] text-muted"
                >
                  —
                </p>
              </div>
            ))
          }
        </div>
      </section>

      {/* ── Daily burn chart ───────────────────────────────────── */}
      <section
        data-llms-chart-section
        class="llms-sec mb-12"
        style="animation-delay:160ms"
      >
        <div class="mb-3 flex items-center gap-3">
          <h2 class="m-0 font-mono text-[13px] tracking-widest text-muted uppercase">
            daily burn
          </h2>
          <span class="h-px flex-1 bg-line" aria-hidden="true"></span>
          <span class="font-mono text-[11px] text-muted">
            <span data-llms-chart-count>loading</span> ·{' '}
            <span data-llms-chart-peak>peak —</span>
          </span>
        </div>
        <div class="rounded-2xl border border-line bg-white p-4 shadow-[4px_4px_0_var(--color-line)]">
          <div class="relative h-44 pl-11">
            <div class="absolute right-0 left-11" style="top:0%">
              <span
                data-llms-chart-scale-max
                class="absolute right-full mr-2 -translate-y-1/2 font-mono text-[9px] text-muted tabular-nums"
              >
                —
              </span>
              <span
                class="block h-px w-full"
                style="border-top:1px dashed var(--color-line)"></span>
            </div>
            <div class="absolute right-0 left-11" style="top:50%">
              <span
                data-llms-chart-scale-mid
                class="absolute right-full mr-2 -translate-y-1/2 font-mono text-[9px] text-muted tabular-nums"
              >
                —
              </span>
              <span
                class="block h-px w-full"
                style="border-top:1px dashed var(--color-line)"></span>
            </div>
            <div class="absolute right-0 left-11" style="top:100%">
              <span class="absolute right-full mr-2 -translate-y-1/2 font-mono text-[9px] text-muted tabular-nums">
                0
              </span>
              <span
                class="block h-px w-full"
                style="background:var(--color-line)"></span>
            </div>
            <div
              data-llms-chart-bars
              class="absolute inset-0 left-11 flex items-end gap-px"
            >
            </div>
          </div>
          <div class="mt-2 flex justify-between pl-11 font-mono text-[10px] text-muted">
            <span data-llms-chart-first-day>—</span>
            <span data-llms-chart-last-day>—</span>
          </div>
        </div>
      </section>

      {/* ── By model ───────────────────────────────────────────── */}
      <section
        data-llms-models-section
        class="llms-sec mb-10"
        style="animation-delay:220ms"
      >
        <div class="mb-3 flex items-center gap-3">
          <h2 class="m-0 font-mono text-[13px] tracking-widest text-muted uppercase">
            by model
          </h2>
          <span class="h-px flex-1 bg-line" aria-hidden="true"></span>
          <span data-llms-model-count class="font-mono text-[11px] text-muted">
            loading
          </span>
        </div>

        <div
          data-llms-models
          class="overflow-hidden rounded-2xl border border-line bg-white shadow-[4px_4px_0_var(--color-line)]"
        >
          <div class="px-4 py-3 font-mono text-[12px] text-muted">
            loading model breakdown…
          </div>
        </div>
      </section>

      {/* ── Provenance ─────────────────────────────────────────── */}
      <p
        class="llms-sec font-mono text-[11px] leading-relaxed text-muted"
        style="animation-delay:280ms"
      >
        <span class="text-ink/70">machines</span>{' '}
        <span data-llms-machines>loading…</span>
        <span data-llms-last-activity-wrap hidden>
          {' '}· <span class="text-ink/70">last activity</span>{' '}
          <span data-llms-last-activity></span>
        </span>
      </p>
    </div>
  </StudioShell>
</BaseLayout>

<script>
  import '~/components/studio/llms/client/hydrate'
</script>

<style>
  @keyframes llms-rise {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes llms-grow {
    from {
      transform: scaleY(0);
    }
    to {
      transform: scaleY(1);
    }
  }
  .llms-sec {
    animation: llms-rise 0.55s cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }
  .llms-bar {
    transform-origin: bottom;
    animation: llms-grow 0.6s cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }
  @media (prefers-reduced-motion: reduce) {
    .llms-sec,
    .llms-bar {
      animation: none;
    }
  }
</style>
