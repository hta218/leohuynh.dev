---
import StudioShell from '~/components/studio/StudioShell.astro'
import BaseLayout from '~/layouts/BaseLayout.astro'
import { getMovies, type Movie } from '~/lib/media'
import { SITE } from '~/lib/site'

const movies = getMovies().sort((a, b) => {
  if (b.yourRating === a.yourRating) return b.imdbRating - a.imdbRating
  return b.yourRating - a.yourRating
})

const groupedMovies = movies.reduce<Array<{ rating: number; movies: Movie[] }>>(
  (groups, movie) => {
    const group = groups.find((item) => item.rating === movie.yourRating)
    if (group) {
      group.movies.push(movie)
    } else {
      groups.push({ rating: movie.yourRating, movies: [movie] })
    }
    return groups
  },
  [],
)

function meta(movie: Movie): string {
  return [movie.year, movie.titleType, movie.genres?.split(',')[0], movie.runtime ? `${movie.runtime}m` : undefined]
    .filter(Boolean)
    .join(' · ')
}
---

<BaseLayout title="My movies list" description="Movies and TV series I've watched, exported from my IMDb ratings.">
  <StudioShell active="/movies" crumb="~/leohuynh.dev/movies/">
    <header class="mb-9 border-b border-line pb-7">
      <h1 class="m-0 text-[clamp(34px,6vw,58px)] leading-[0.95] tracking-[-0.05em]">Movies</h1>
      <p class="mt-4 max-w-[680px] text-lg text-muted">
        Where I log the movies and TV series I've watched. Big fan of Tom Hanks and Christopher
        Nolan — anything rated 10 is something I love and have probably rewatched many times.
      </p>
      <p class="mt-2 font-mono text-xs text-muted">
        *Exported from my{' '}
        <a href={SITE.imdbRatingsList} target="_blank" rel="noreferrer" class="text-code-blue"
          >IMDb ratings</a
        >, enriched via the OMDB API.
      </p>
    </header>

    {
      groupedMovies.length === 0 ? (
        <p class="rounded-xl border border-line bg-white p-6 font-mono text-sm text-muted">
          Movies snapshot unavailable right now.
        </p>
      ) : (
        <div class="space-y-8">
          {groupedMovies.map((group) => (
            <section class="space-y-3">
              <div class="flex items-end justify-between gap-3 border-b border-line pb-2">
                <h2 class="m-0 text-[22px] tracking-[-0.04em]">
                  My rating {group.rating}/10
                </h2>
                <span class="font-mono text-xs text-muted">{group.movies.length} titles</span>
              </div>
              <div class="divide-y divide-line overflow-hidden rounded-2xl border border-line bg-white">
                {group.movies.map((m) => (
                  <a
                    href={m.url}
                    target="_blank"
                    rel="noreferrer"
                    class="group grid gap-3 p-3 no-underline hover:bg-panel2 sm:grid-cols-[58px_1fr_auto] sm:items-center"
                  >
                    <div class="h-[86px] w-[58px] overflow-hidden rounded-lg border border-line bg-panel2 sm:h-[76px] sm:w-[50px]">
                      {m.poster ? (
                        <img
                          src={m.poster}
                          alt={m.title}
                          loading="lazy"
                          class="h-full w-full object-cover transition-transform group-hover:scale-[1.04]"
                        />
                      ) : (
                        <div class="grid h-full w-full place-items-center font-mono text-[10px] text-muted">
                          IMDb
                        </div>
                      )}
                    </div>
                    <div class="min-w-0">
                      <h3 class="m-0 truncate text-[15px] font-semibold leading-snug tracking-[-0.01em] text-ink group-hover:text-code-blue">
                        {m.title}
                      </h3>
                      <p class="mt-1 mb-0 truncate font-mono text-[11px] text-muted">
                        {meta(m)}
                      </p>
                      {m.directors && (
                        <p class="mt-1 mb-0 truncate text-[12px] text-muted">
                          Directed by {m.directors}
                        </p>
                      )}
                    </div>
                    <div class="flex flex-wrap gap-1.5 font-mono text-[11px] sm:justify-end">
                      <span class="rounded-md border border-line bg-panel px-2 py-1 text-ink">
                        my ★ {m.yourRating}
                      </span>
                      <span class="rounded-md border border-line bg-[#f5c518] px-2 py-1 text-ink">
                        IMDb {m.imdbRating || '—'}
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>
      )
    }
  </StudioShell>
</BaseLayout>
