---
import PageHeader from '~/components/PageHeader.astro'
import StudioShell from '~/components/studio/StudioShell.astro'
import BaseLayout from '~/layouts/BaseLayout.astro'

const SECTIONS = [
  {
    title: 'Work, Product & Customers',
    takes: [
      'Useful beats impressive.',
      'I stay close to the work — the answers live there, not in the status call.',
      'Small teams need clearer systems, not more meetings.',
      'Speed matters, but panic is not speed.',
      'I build for the people actually using the thing, not the demo.',
      'Good developer experience is product work, not a nice-to-have.',
      'A CMS should make a team faster, not make engineers feel trapped.',
      'Hydrogen should feel powerful without becoming heavy.',
      'Random design is technical debt with nicer colors.',
      'A blocked customer matters more than a clean internal plan.',
      'During UAT, I unblock the client first; I tidy the code after.',
      "I don't make customers guess: I say what changed, what's blocked, and what happens next.",
      'Silence makes small problems feel big.',
    ],
  },
  {
    title: 'Engineering & AI',
    takes: [
      'Simple systems win because tired people have to maintain them.',
      'APIs are promises. If people depend on an old path, I keep the shim.',
      'I deprecate first, delete later, maybe never.',
      'I never delete something important because it looks unused — I prove it first.',
      'Compatibility is boring until customers lose trust.',
      "AI is useful, but it doesn't own the outcome — I do.",
      "I let AI draft, code, and review; I don't let it decide what good looks like.",
      'A bad spec just creates bad code faster now.',
      'Complex SDK and adapter work still needs a plan and a review.',
      "If I can't review it, I shouldn't ship it.",
    ],
  },
  {
    title: 'People',
    takes: [
      'I say the hard thing kindly — but I say it.',
      "I'm the same person in the room and behind someone's back.",
      'I apologize fast. Ego is expensive.',
      "I can't fake respect; people can smell it.",
      'I assume good intent, until people give me a reason not to.',
    ],
  },
  {
    title: 'Life & Family',
    takes: [
      "Health is the one thing I can't refactor later.",
      'Boring and consistent beats intense and gone by next month.',
      "If I'm always busy, that's a choice I keep making.",
      'Most things are not as urgent as they feel.',
      "I won't remember the late nights, only who I spent them with.",
      'I try to be home for dinner more often than I think I can afford to.',
      'I answer the people I love before the people who pay me.',
      'Time with family is the one budget I never earn back.',
      "My kids won't remember a perfect dad, just a present one.",
    ],
  },
]
---

<BaseLayout
  title="takes"
  description="My takes on building software, showing up for people, staying honest, and not repeating the same mistakes."
>
  <StudioShell active="/takes" crumb="~/leohuynh.dev/takes.md">
    <PageHeader
      title="My takes"
      description="On building software, working with humans / AI, living my life, raising my son, and not repeating the same mistakes."
    />

    <div class="space-y-10">
      {
        SECTIONS.map((section, i) => (
          <section>
            <div class="mb-4 flex items-baseline gap-3 border-b border-line pb-2">
              <span class="font-mono text-xs text-code-blue">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h2 class="m-0 text-xl font-semibold tracking-[-0.02em]">
                {section.title}
              </h2>
            </div>
            <ul class="space-y-2.5">
              {section.takes.map((take) => (
                <li class="flex gap-3 text-[15px] leading-relaxed text-ink">
                  <span class="mt-2.5 h-1.5 w-1.5 shrink-0 rounded-full bg-line" />
                  <span>{take}</span>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>

    <p class="mt-12 border-t border-line pt-6 font-mono text-xs text-muted">
      Subject to change. That's the point.
    </p>
  </StudioShell>
</BaseLayout>
