const sectionId = (title: string) =>
  title.toLowerCase().replace(/[^a-z0-9]+/g, '-')

/** Auto logo from a link's domain when no local image is provided. */
function thumbFor(item: UseItem): string | undefined {
  if (item.image) return item.image
  if (!item.href) return undefined
  try {
    const { hostname } = new URL(item.href)
    return `https://www.google.com/s2/favicons?domain=${hostname}&sz=128`
  } catch {
    return undefined
  }
}
---

<BaseLayout
  title="uses"
  description="The hardware, editor setup, apps, and dev tools I use every day."
>
  <StudioShell active="/uses" crumb="~/leohuynh.dev/uses.md">
    <PageHeader
      title="Uses"
      description="The gear, editor setup, apps, and tools I reach for every day. Inspired by uses.tech — a living list, subject to change."
    >
      <nav class="mt-4 flex flex-wrap gap-4 font-mono text-xs">
        {
          SECTIONS.map((section) => (
            <a
              href={`#${sectionId(section.title)}`}
              class="text-code-blue no-underline"
            >
              → {section.title.toLowerCase()}
            </a>
          ))
        }
      </nav>
    </PageHeader>

    <div class="space-y-12">
      {
        SECTIONS.map((section) => (
          <section id={sectionId(section.title)} class="scroll-mt-24">
            <div class="mb-5 flex items-center gap-2.5 border-b border-line pb-2">
              <HugeIcon name={section.icon} size={18} class="text-code-blue" />
              <h2 class="m-0 text-[22px] tracking-[-0.04em]">{section.title}</h2>
              <span class="ml-auto font-mono text-xs text-muted">
                {section.items.length} items
              </span>
            </div>

            <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
              {section.items.map((item) => {
                const thumb = thumbFor(item)
                const Tag = item.href ? 'a' : 'div'
                return (
                  <Tag
                    href={item.href}
                    target={item.href ? '_blank' : undefined}
                    rel={item.href ? 'noreferrer' : undefined}
                    class:list={[
                      'group flex items-center gap-4 rounded-2xl border border-line bg-white p-4 no-underline',
                      item.href &&
                        'hover:border-code-blue hover:shadow-[4px_4px_0_var(--color-line)]',
                    ]}
                  >
                    <span class="relative grid h-12 w-12 flex-none place-items-center overflow-hidden rounded-xl border border-line bg-panel2">
                      {thumb && (
                        <img
                          src={thumb}
                          alt={item.name}
                          loading="lazy"
                          onerror="this.remove()"
                          class="h-full w-full object-contain p-2"
                        />
                      )}
                    </span>

                    <div class="min-w-0 flex-1">
                      <div class="flex items-baseline gap-2">
                        <h3 class="m-0 truncate text-[16px] font-semibold tracking-[-0.02em] text-ink group-hover:text-code-blue">
                          {item.name}
                        </h3>
                        {item.meta && (
                          <span class="flex-none font-mono text-[11px] text-muted">
                            {item.meta}
                          </span>
                        )}
                        {item.href && (
                          <span class="ml-auto flex-none font-mono text-xs text-muted group-hover:text-code-blue">
                            ↗
                          </span>
                        )}
                      </div>
                      {item.description && (
                        <p class="mt-1 mb-0 text-[14px] leading-relaxed text-muted">
                          {item.description}
                        </p>
                      )}
                    </div>
                  </Tag>
                )
              })}
            </div>
          </section>
        ))
      }
    </div>

    <p class="mt-12 border-t border-line pt-6 font-mono text-xs text-muted">
      A living list. Last shuffled when the setup changed.
    </p>
  </StudioShell>
</BaseLayout>
