---
import HugeIcon from '~/components/icons/HugeIcon.astro'
import PageHeader from '~/components/PageHeader.astro'
import StudioShell from '~/components/studio/StudioShell.astro'
import BaseLayout from '~/layouts/BaseLayout.astro'

type UseItem = {
  name: string
  description?: string
  meta?: string
  href?: string
  /** Local image, e.g. '/uses/macbook.webp'. Falls back to the href favicon. */
  image?: string
}

type IconName =
  | 'keyboard'
  | 'briefcase'
  | 'terminal'
  | 'globe'
  | 'robot'
  | 'star'

type UseSection = {
  title: string
  icon: IconName
  items: UseItem[]
}

