---
import PageHeader from '~/components/PageHeader.astro'
import Twemoji from '~/components/mdx/Twemoji.astro'
import StudioShell from '~/components/studio/StudioShell.astro'
import BaseLayout from '~/layouts/BaseLayout.astro'
import { CAREER, SITE, SUPPORT } from '~/lib/site'

const socials = [
  { label: 'GitHub', href: SITE.github },
  { label: 'X', href: SITE.x },
  { label: 'LinkedIn', href: SITE.linkedin },
  { label: 'Instagram', href: SITE.instagram },
  { label: 'Threads', href: SITE.threads },
  { label: 'YouTube', href: SITE.youtube },
]

const features = [
  { emoji: 'rocket', label: 'Astro 5 static-first + React islands for live widgets.' },
  { emoji: 'artist-palette', label: 'Tailwind CSS v4 with a custom code-studio theme.' },
  { emoji: 'safety-vest', label: 'TypeScript end to end for type safety.' },
  { emoji: 'open-book', label: 'MDX + Astro Content Collections for blog & snippets.' },
  { emoji: 'bar-chart', label: 'Umami for privacy-friendly analytics.' },
  { emoji: 'card-file-box', label: 'Supabase Postgres + Drizzle for stats and lists.' },
]
---

<BaseLayout title="whoami" description="A bit about who I am, what I do, and why I write here.">
  <StudioShell active="/whoami" crumb="~/leohuynh.dev/whoami.md">
    <PageHeader
      title="whoami"
      description="A bit about who I am, what I do, and why I write here — a quick intro to the person typing away behind the scenes."
    />

    <article class="prose">
      <h2 class="!mt-0">
        Hi there <Twemoji emoji="waving-hand" />
      </h2>
      <img
        src="/static/images/leo.jpg"
        alt="Leo Huynh"
        width="3024"
        height="4032"
        class="not-prose mb-6 h-auto w-full rounded-2xl border border-ink shadow-[4px_4px_0_var(--color-ink)]"
      />
      <p>
        I'm <strong>Tuan Anh Huynh</strong> (alias <strong>Leo</strong> at work), a software
        engineer from <strong>Vietnam</strong>. I have a passion for all things
        <strong>JavaScript</strong>. I enjoy building eCommerce software and things related to web
        dev. I work mainly with <strong>TypeScript</strong>, <strong>React</strong>,
        <strong>Node</strong>, <strong>Remix</strong>, and <strong>Next.js</strong>.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-between gap-3">
        <h2 class="!my-0 !border-0">My career</h2>
        <a
          href="/static/resume.pdf"
          target="_blank"
          rel="noreferrer"
          class="group inline-flex items-center gap-1.5 rounded-lg border border-ink bg-white px-3.5 py-2 font-mono text-xs text-ink no-underline shadow-[3px_3px_0_var(--color-ink)] transition-all hover:-translate-x-px hover:-translate-y-px hover:shadow-[4px_4px_0_var(--color-ink)] active:translate-x-px active:translate-y-px active:shadow-[1px_1px_0_var(--color-ink)]"
        >
          <Twemoji emoji="page-facing-up" size="base" className="m-0!" /> View resume
        </a>
      </div>

      <ol class="not-prose mt-6">
        {
          CAREER.map((job, i) => (
            <li class="relative flex gap-4 pb-8 last:pb-0">
              {i < CAREER.length - 1 && (
                <span class="absolute top-12 bottom-0 left-5.75 w-px bg-line" />
              )}
              <img
                src={job.logo}
                alt={job.org}
                width="88"
                height="88"
                loading="lazy"
                decoding="async"
                class="relative z-10 h-12 w-12 shrink-0 rounded-lg border border-line bg-white object-contain p-1"
              />
              <div class="min-w-0 flex-1 pt-0.5">
                <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1">
                  <h3 class="m-0 text-[17px] leading-snug font-semibold tracking-[-0.02em]">
                    {job.role}{' '}
                    <span class="font-normal text-muted">
                      @{' '}
                      <a href={job.url} target="_blank" rel="noreferrer" class="text-code-blue">
                        {job.org}
                      </a>
                    </span>
                  </h3>
                  <span class="rounded-md border border-line bg-panel2 px-2 py-0.5 font-mono text-[11px] whitespace-nowrap text-muted">
                    {job.period}
                  </span>
                </div>
                <ul class="mt-2 mb-0 list-disc space-y-1 pl-5 text-[15px] text-muted marker:text-line">
                  {job.notes.map((n) => (
                    <li set:html={n} />
                  ))}
                </ul>
              </div>
            </li>
          ))
        }
      </ol>

      <h2>Why this blog?</h2>
      <blockquote><p>Because sharing is learning.</p></blockquote>
      <p>
        I started this blog to document and share the things I've learned as a software engineer.
        Writing things down is a great way to solidify my understanding of new concepts — and I
        hope it's a helpful resource for others into web development and eCommerce.
      </p>

      <h2>What it's built with</h2>
      <ul class="not-prose mt-6 space-y-2.5">
        {
          features.map((f) => (
            <li class="flex items-start gap-2.5 text-[15px] leading-relaxed">
              <Twemoji emoji={f.emoji} size="base" className="mt-1 m-0! shrink-0" />
              <span>{f.label}</span>
            </li>
          ))
        }
      </ul>

      <h2>Contact</h2>
      <p>
        Reach me at <a href={`mailto:${SITE.email}`}>{SITE.email}</a> or find me on social:
      </p>
      <div class="not-prose flex flex-wrap gap-2">
        {
          socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noreferrer"
              class="rounded-full border border-line bg-white px-3 py-1.5 font-mono text-xs text-ink no-underline hover:text-code-blue"
            >
              {s.label}
            </a>
          ))
        }
      </div>

      <h2>Support</h2>
      <p>If you appreciate my work, consider supporting me <Twemoji emoji="folded-hands" /></p>
      <div class="not-prose flex flex-wrap gap-2">
        <a
          href={SUPPORT.buyMeACoffee}
          target="_blank"
          rel="noreferrer"
          class="rounded-lg border border-line bg-white px-3 py-1.5 font-mono text-xs no-underline hover:text-code-blue"
          >Buy me a coffee</a
        >
        <a
          href={SUPPORT.kofi}
          target="_blank"
          rel="noreferrer"
          class="rounded-lg border border-line bg-white px-3 py-1.5 font-mono text-xs no-underline hover:text-code-blue"
          >Ko-fi</a
        >
        <a
          href={SUPPORT.paypal}
          target="_blank"
          rel="noreferrer"
          class="rounded-lg border border-line bg-white px-3 py-1.5 font-mono text-xs no-underline hover:text-code-blue"
          >PayPal</a
        >
      </div>
    </article>
  </StudioShell>
</BaseLayout>
