---
import {
  Analytics01Icon,
  ArrowDown01Icon,
  ArrowRight01Icon,
  BookOpen01Icon,
  CodeSquareIcon,
  ExternalLinkIcon,
  File01Icon,
  FileCodeIcon,
  FolderOpenIcon,
  KeyboardIcon,
  Message02Icon,
  Note01Icon,
  StarIcon,
  Tag01Icon,
  UserCircleIcon,
} from '@hugeicons/core-free-icons'
import { HugeiconsIcon } from '@hugeicons/react'

type IconName =
  | 'analytics'
  | 'book'
  | 'caret-down'
  | 'caret-right'
  | 'comment'
  | 'external'
  | 'file'
  | 'folder'
  | 'keyboard'
  | 'markdown'
  | 'project'
  | 'star'
  | 'tag'
  | 'user'
  | 'code'

interface Props {
  name: IconName
  class?: string
  size?: number
  strokeWidth?: number
  title?: string
}

const {
  name,
  class: className = '',
  size = 15,
  strokeWidth = 1.8,
  title,
} = Astro.props

const ICONS = {
  analytics: Analytics01Icon,
  book: BookOpen01Icon,
  'caret-down': ArrowDown01Icon,
  'caret-right': ArrowRight01Icon,
  comment: Message02Icon,
  external: ExternalLinkIcon,
  file: File01Icon,
  folder: FolderOpenIcon,
  keyboard: KeyboardIcon,
  markdown: Note01Icon,
  project: CodeSquareIcon,
  star: StarIcon,
  tag: Tag01Icon,
  user: UserCircleIcon,
  code: FileCodeIcon,
} as const
---

<span class:list={['huge-icon', className]} title={title} aria-hidden={title ? undefined : 'true'}>
  <HugeiconsIcon icon={ICONS[name]} size={size} strokeWidth={strokeWidth} />
</span>
