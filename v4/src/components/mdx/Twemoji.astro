---
/**
 * Renders legacy `<Twemoji emoji="name" />` tags as local Twemoji SVG images.
 * This keeps content authoring stable while replacing the legacy hand-written
 * `.twa-*` CSS map with a small TS codepoint map + generated assets.
 */
import { emojiCodepoint } from '~/lib/emoji'

interface Props {
  emoji: string
  /** Optional extra classes; mirrors the legacy `className` contract. */
  className?: string
  size?: 'base' | 'lg' | '2x'
}

const { emoji, className = '', size = 'lg' } = Astro.props
const codepoint = emojiCodepoint(emoji)
const label = emoji.replace(/-/g, ' ')
const sizeClass =
  size === 'base' ? 'twemoji-base' : size === '2x' ? 'twemoji-2x' : 'twemoji-lg'
---

{
  codepoint && (
    <img
      src={`/static/twemoji/${codepoint}.svg`}
      alt={label}
      title={label}
      loading="lazy"
      decoding="async"
      class:list={['twemoji', sizeClass, className]}
    />
  )
}
