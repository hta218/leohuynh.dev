---
/**
 * Renders the real Unicode emoji glyph for a legacy `<Twemoji emoji="name" />` tag
 * (212 inline uses across migrated MDX). Replaces the M2 CSS-class placeholder with
 * a non-breaking, asset-free glyph mapped from the legacy twemoji codepoints.
 *
 * Unknown names resolve to an empty glyph, so prose never crashes or shows a tofu box.
 */
import { emojiGlyph } from '~/lib/emoji'

interface Props {
  emoji: string
  /** Optional extra classes; mirrors the legacy `className` contract. */
  className?: string
}

const { emoji, className = '' } = Astro.props
const glyph = emojiGlyph(emoji)
---

<span
  class:list={['twemoji', className]}
  role="img"
  aria-label={emoji.replace(/-/g, ' ')}
  title={emoji.replace(/-/g, ' ')}>{glyph}</span
>
