---
import AstroIcon from '../../../../icons/astro.svg?raw'
import GitHubIcon from '../../../../icons/github.svg?raw'
import GoodreadsIcon from '../../../../icons/goodreads.svg?raw'
import ImdbIcon from '../../../../icons/imdb.svg?raw'
import MarkdownIcon from '../../../../icons/markdown.svg?raw'
import UmamiIcon from '../../../../icons/umami.svg?raw'
import VSCodeIcon from '../../../../icons/vscode.svg?raw'
import { getCollection } from 'astro:content'
import { MORE_LINKS, NAV_LINKS } from '~/lib/site'
import RuntimeRail from './RuntimeRail.astro'

interface Props {
  /** path used to highlight the active explorer entry, e.g. "/blog" */
  active?: string
  /** breadcrumb shown above the main content, e.g. "~/leohuynh.dev/main" */
  crumb?: string
}

type IconName =
  | 'astro'
  | 'markdown'
  | 'github'
  | 'goodreads'
  | 'imdb'
  | 'umami'
  | 'vscode'

const { active = '/', crumb = '~/leohuynh.dev/main' } = Astro.props
const isExternal = (href: string) => href.startsWith('http')
const isPublished = (d: { data: { draft?: boolean } }) => d.data.draft !== true

const ICONS: Record<IconName, string> = {
  astro: AstroIcon,
  markdown: MarkdownIcon,
  github: GitHubIcon,
  goodreads: GoodreadsIcon,
  imdb: ImdbIcon,
  umami: UmamiIcon,
  vscode: VSCodeIcon,
}

const [posts, snippets] = await Promise.all([
  getCollection('blog', isPublished),
  getCollection('snippets', isPublished),
])

const latestPost = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0]
const latestSnippet = snippets.sort((a, b) => b.id.localeCompare(a.id))[0]

const routeFolders = [
  {
    label: 'posts/',
    items: [
      { href: '/blog', file: 'index.astro' },
      { href: latestPost ? `/blog/${latestPost.id}` : '/blog', file: '[...slug].astro' },
    ],
  },
  {
    label: 'snippets/',
    items: [
      { href: '/snippets', file: 'index.astro' },
      {
        href: latestSnippet ? `/snippets/${latestSnippet.id}` : '/snippets',
        file: '[...slug].astro',
      },
    ],
  },
]

const routeLinks: Array<{
  href: string
  title: string
  icon: IconName
  file: string
}> = [
  { href: '/', title: 'Home', icon: 'markdown', file: 'README.md' },
  ...NAV_LINKS.map((link) => ({
    ...link,
    icon: link.href === '/projects' ? ('github' as const) : ('astro' as const),
    file:
      link.href === '/blog'
        ? 'blog/index.astro'
        : link.href === '/snippets'
          ? 'snippets/index.astro'
          : link.href === '/projects'
            ? 'projects.astro'
            : 'about.astro',
  })),
  ...MORE_LINKS.map((link) => ({
    ...link,
    icon:
      link.href === '/books'
        ? ('goodreads' as const)
        : link.href === '/movies'
          ? ('imdb' as const)
          : link.href === '/tags'
            ? ('astro' as const)
            : ('umami' as const),
    file:
      link.href === '/books'
        ? 'books.astro'
        : link.href === '/movies'
          ? 'movies.astro'
          : link.href === '/tags'
            ? 'tags/index.astro'
            : 'analytics.url',
  })),
]

const tabLinks = routeLinks.filter((link) => !isExternal(link.href)).slice(0, 5)
const shellId = `studio-${Math.random().toString(36).slice(2)}`
---

<div id={shellId} class="studio-shell grid h-screen grid-rows-[1fr_30px] overflow-hidden bg-bg" data-rail="visible">
  <div class="studio-workspace grid min-h-0 grid-cols-1 overflow-hidden lg:grid-cols-[260px_minmax(0,1fr)_360px]">
    <aside class="thin-scrollbar hidden min-h-0 overflow-y-auto border-r border-line bg-[#f8fafc] p-3 lg:block">
      <a href="/" class="mb-4 flex items-center gap-2.5 font-extrabold no-underline text-ink">
        <span class="grid h-[30px] w-[30px] place-items-center rounded-lg border border-ink bg-white font-mono text-xs shadow-[3px_3px_0_var(--color-ink)]">LH</span>
        <span>leo workspace</span>
      </a>

      <section class="mb-5">
        <h3 class="mb-2 font-mono text-[11px] uppercase tracking-[0.08em] text-muted">routes</h3>
        <div class="space-y-3">
          {
            routeFolders.map((folder) => (
              <div>
                <div class="mb-1 flex items-center gap-2 px-2 font-mono text-xs font-semibold text-slate-700">
                  <span class="brand-icon text-slate-500" set:html={ICONS.astro} />
                  <span>{folder.label}</span>
                </div>
                <div class="space-y-1 pl-4">
                  {folder.items.map((item) => (
                    <a
                      href={item.href}
                      class="flex items-center gap-2 rounded-md px-2 py-[5px] font-mono text-[11px] text-slate-600 no-underline hover:bg-slate-100 hover:text-slate-950"
                    >
                      <span class="brand-icon text-slate-500" set:html={ICONS.astro} />
                      <span>{item.file}</span>
                    </a>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <section class="mb-5">
        <h3 class="mb-2 font-mono text-[11px] uppercase tracking-[0.08em] text-muted">explorer</h3>
        <nav class="space-y-1">
          {
            routeLinks.map((item) => (
              <a
                href={item.href}
                target={isExternal(item.href) ? '_blank' : undefined}
                rel={isExternal(item.href) ? 'noreferrer' : undefined}
                class:list={[
                  'flex items-center gap-2 rounded-md px-2 py-[6px] font-mono text-xs no-underline',
                  active === item.href
                    ? 'bg-slate-200 text-slate-950'
                    : 'text-slate-600 hover:bg-slate-100 hover:text-slate-950',
                ]}
              >
                <span class="brand-icon text-slate-500" set:html={ICONS[item.icon]} />
                <span>{item.file}</span>
              </a>
            ))
          }
        </nav>
      </section>
    </aside>

    <main class="flex min-h-0 min-w-0 flex-col overflow-hidden bg-panel [background-image:linear-gradient(90deg,rgba(15,23,42,0.03)_1px,transparent_1px)] [background-size:64px_64px]">
      <nav class="flex shrink-0 items-stretch border-b border-line bg-[#fbfcff]">
        <div class="thin-scrollbar flex min-w-0 flex-1 overflow-x-auto">
          {
            tabLinks.map((l) => (
              <a
                href={l.href}
                class:list={[
                  'shrink-0 border-r border-line px-3.5 py-[10px] font-mono text-xs no-underline',
                  active === l.href
                    ? 'bg-white text-slate-950 shadow-[inset_0_-2px_0_var(--color-ink)]'
                    : 'text-muted hover:text-slate-950',
                ]}
              >
                <span class="brand-icon mr-2 inline-grid align-[-2px] text-slate-500" set:html={ICONS[l.icon]} />
                {l.file}
              </a>
            ))
          }
        </div>
        <button
          type="button"
          class="hidden shrink-0 border-l border-line bg-[#fbfcff] px-3.5 py-[10px] font-mono text-xs text-muted hover:bg-white hover:text-slate-950 lg:block"
          data-toggle-rail
          aria-controls="runtime-rail"
          aria-expanded="true"
        >
          hide right rail
        </button>
      </nav>

      <div class="thin-scrollbar min-h-0 flex-1 overflow-y-auto px-[clamp(22px,5vw,78px)] pt-[38px] pb-[70px]">
        <div class="mb-[18px] font-mono text-xs text-slate-500">{crumb}</div>
        <slot />
      </div>
    </main>

    <RuntimeRail />
  </div>

  <footer class="flex items-center justify-between border-t border-line bg-white px-3 font-mono text-xs text-slate-600">
    <span>v4 preview · v3 preserved · production pending</span>
    <span>rss · github · x · analytics</span>
  </footer>
</div>

<script is:inline>
  function initStudioShell() {
    document.querySelectorAll('.studio-shell').forEach((shell) => {
      const toggle = shell.querySelector('[data-toggle-rail]')
      const saved = localStorage.getItem('leohuynh:right-rail') || 'visible'
      const setRail = (state) => {
        shell.dataset.rail = state
        if (toggle) {
          toggle.textContent = state === 'hidden' ? 'show right rail' : 'hide right rail'
          toggle.setAttribute('aria-expanded', String(state !== 'hidden'))
        }
        localStorage.setItem('leohuynh:right-rail', state)
      }
      setRail(saved)
      if (toggle && !toggle.dataset.bound) {
        toggle.dataset.bound = 'true'
        toggle.addEventListener('click', () => {
          setRail(shell.dataset.rail === 'hidden' ? 'visible' : 'hidden')
        })
      }
    })
  }

  initStudioShell()
  document.addEventListener('astro:page-load', initStudioShell)
</script>
