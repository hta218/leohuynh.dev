---
import { execSync } from 'node:child_process'
import AstroIcon from '../../../../icons/astro.svg?raw'
import GoodreadsIcon from '../../../../icons/goodreads.svg?raw'
import ImdbIcon from '../../../../icons/imdb.svg?raw'
import MarkdownIcon from '../../../../icons/markdown.svg?raw'
import UmamiIcon from '../../../../icons/umami.svg?raw'
import { getCollection } from 'astro:content'
import HugeIcon from '~/components/icons/HugeIcon.astro'
import { SITE } from '~/lib/site'
import RuntimeRail from './RuntimeRail.astro'

interface Props {
  /** path used to highlight the active explorer entry, e.g. "/blog" */
  active?: string
  /** breadcrumb shown above the main content, e.g. "~/leohuynh.dev/main" */
  crumb?: string
}

type BrandIconName = 'astro' | 'goodreads' | 'imdb' | 'markdown' | 'umami'
type HugeIconName =
  | 'analytics'
  | 'book'
  | 'caret-down'
  | 'caret-right'
  | 'comment'
  | 'external'
  | 'file'
  | 'folder'
  | 'folder-open'
  | 'keyboard'
  | 'markdown'
  | 'project'
  | 'rocket'
  | 'star'
  | 'tag'
  | 'user'
  | 'code'
type IconSpec =
  | { type: 'brand'; name: BrandIconName }
  | { type: 'huge'; name: HugeIconName }

type TreeLeaf = {
  kind: 'leaf'
  id: string
  href: string
  file: string
  title?: string
  icon: IconSpec
  external?: boolean
  openHint?: boolean
  activeWhen?: (path: string) => boolean
}

type TreeFolder = {
  kind: 'folder'
  id: string
  href?: string
  file: string
  title?: string
  icon: IconSpec
  children: TreeLeaf[]
  activeWhen?: (path: string) => boolean
}

type TreeItem = TreeLeaf | TreeFolder

const { active, crumb = '~/leohuynh.dev/main' } = Astro.props
const currentPath = (active ?? Astro.url.pathname.replace(/\/$/, '')) || '/'
const isExternal = (href: string) => href.startsWith('http')
const isPublished = (d: { data: { draft?: boolean } }) => d.data.draft !== true

const BRAND_ICONS: Record<BrandIconName, string> = {
  astro: AstroIcon,
  goodreads: GoodreadsIcon,
  imdb: ImdbIcon,
  markdown: MarkdownIcon,
  umami: UmamiIcon,
}

const [posts, snippets] = await Promise.all([
  getCollection('blog', isPublished),
  getCollection('snippets', isPublished),
])

const latestPost = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0]
const latestSnippet = snippets.sort((a, b) => b.id.localeCompare(a.id))[0]

const exact = (href: string) => (path: string) => path === href
const startsWith = (prefix: string) => (path: string) =>
  path === prefix || path.startsWith(`${prefix}/`)

const postsIndex: TreeLeaf = {
  kind: 'leaf',
  id: 'posts-index',
  href: '/blog',
  file: 'index.astro',
  title: 'Posts index',
  icon: { type: 'brand', name: 'astro' },
  activeWhen: (path) => path === '/blog' || path.startsWith('/blog/page/'),
}
const postsSlug: TreeLeaf = {
  kind: 'leaf',
  id: 'posts-slug',
  href: latestPost ? `/blog/${latestPost.id}` : '/blog',
  file: '[...slug].astro',
  title: 'Post detail template',
  icon: { type: 'brand', name: 'astro' },
  activeWhen: (path) => path.startsWith('/blog/') && !path.startsWith('/blog/page/'),
}
const snippetsIndex: TreeLeaf = {
  kind: 'leaf',
  id: 'snippets-index',
  href: '/snippets',
  file: 'index.astro',
  title: 'Snippets index',
  icon: { type: 'brand', name: 'astro' },
  activeWhen: exact('/snippets'),
}
const snippetsSlug: TreeLeaf = {
  kind: 'leaf',
  id: 'snippets-slug',
  href: latestSnippet ? `/snippets/${latestSnippet.id}` : '/snippets',
  file: '[...slug].astro',
  title: 'Snippet detail template',
  icon: { type: 'brand', name: 'astro' },
  activeWhen: (path) => path.startsWith('/snippets/'),
}

const explorerItems: TreeItem[] = [
  {
    kind: 'leaf',
    id: 'readme',
    href: '/',
    file: 'README.md',
    title: 'Home',
    icon: { type: 'brand', name: 'markdown' },
    activeWhen: exact('/'),
  },
  {
    kind: 'folder',
    id: 'posts-folder',
    file: 'posts',
    title: 'Posts',
    icon: { type: 'huge', name: 'folder' },
    children: [postsIndex, postsSlug],
    activeWhen: startsWith('/blog'),
  },
  {
    kind: 'folder',
    id: 'snippets-folder',
    file: 'snippets',
    title: 'Snippets',
    icon: { type: 'huge', name: 'folder' },
    children: [snippetsIndex, snippetsSlug],
    activeWhen: startsWith('/snippets'),
  },
  {
    kind: 'leaf',
    id: 'projects',
    href: '/projects',
    file: 'projects.astro',
    title: 'Projects',
    icon: { type: 'huge', name: 'rocket' },
    activeWhen: exact('/projects'),
  },
  {
    kind: 'leaf',
    id: 'about',
    href: '/about',
    file: 'about.md',
    title: 'About',
    icon: { type: 'brand', name: 'markdown' },
    activeWhen: exact('/about'),
  },
  {
    kind: 'leaf',
    id: 'books',
    href: '/books',
    file: 'books.astro',
    title: 'Books',
    icon: { type: 'brand', name: 'goodreads' },
    activeWhen: exact('/books'),
  },
  {
    kind: 'leaf',
    id: 'movies',
    href: '/movies',
    file: 'movies.astro',
    title: 'Movies',
    icon: { type: 'brand', name: 'imdb' },
    activeWhen: exact('/movies'),
  },
  {
    kind: 'leaf',
    id: 'tags',
    href: '/tags',
    file: 'tags',
    title: 'Tags',
    icon: { type: 'huge', name: 'tag' },
    activeWhen: startsWith('/tags'),
  },
  {
    kind: 'leaf',
    id: 'stats',
    href: SITE.analytics.umamiShareUrl,
    file: 'stats',
    title: 'Stats',
    icon: { type: 'brand', name: 'umami' },
    external: true,
    openHint: true,
  },
]

const tabLinks: TreeLeaf[] = [
  explorerItems.find((item) => item.kind === 'leaf' && item.id === 'readme') as TreeLeaf,
  { ...postsIndex, file: 'posts/index.astro' },
  { ...snippetsIndex, file: 'snippets/index.astro' },
  explorerItems.find((item) => item.kind === 'leaf' && item.id === 'projects') as TreeLeaf,
  explorerItems.find((item) => item.kind === 'leaf' && item.id === 'about') as TreeLeaf,
]

const shellId = `studio-${Math.random().toString(36).slice(2)}`
const isActive = (item: { href: string; activeWhen?: (path: string) => boolean }) =>
  item.activeWhen ? item.activeWhen(currentPath) : currentPath === item.href
const renderCommit = () => {
  const sha = process.env.VERCEL_GIT_COMMIT_SHA?.slice(0, 7)
  if (sha) return sha
  try {
    return execSync('git rev-parse --short HEAD', { encoding: 'utf8' }).trim()
  } catch {
    return 'local'
  }
}
const lastCommit = renderCommit()
const lastCommitUrl =
  lastCommit && lastCommit !== 'local'
    ? `${SITE.siteRepo}/commit/${lastCommit}`
    : SITE.siteRepo
const SITE_VERSIONS = [
  { value: 'latest', label: 'latest', href: '/', current: true },
  { value: 'v3', label: 'v3', href: 'https://www.leohuynh.dev/' },
  { value: 'v2', label: 'v2', href: 'https://leohuynhdev-git-v2-leo-huynhs-projects.vercel.app/' },
  { value: 'v1', label: 'v1', href: 'https://leohuynhdev-git-v1-leo-huynhs-projects.vercel.app/' },
]
---

<div id={shellId} class="studio-shell grid h-screen grid-rows-[1fr_32px] overflow-hidden bg-bg" data-rail="visible">
  <div class="studio-workspace grid min-h-0 grid-cols-1 overflow-hidden lg:grid-cols-[260px_minmax(0,1fr)_360px]">
    <aside class="thin-scrollbar hidden min-h-0 overflow-y-auto border-r border-line bg-[#f8fafc] px-3 py-3 lg:block">
      <a href="/" class="mb-4 flex items-center gap-2.5 font-extrabold no-underline text-ink">
        <img
          src="/static/images/avatar.jpg"
          alt="Leo Huynh"
          width="36"
          height="36"
          class="h-9 w-9 rounded-xl border border-ink object-cover shadow-[3px_3px_0_var(--color-ink)]"
        />
        <span>leo workspace</span>
      </a>

      <section class="mb-5">
        <h3 class="mb-2 font-mono text-[11px] uppercase tracking-[0.08em] text-muted">explorer</h3>
        <nav class="space-y-0.5">
          {
            explorerItems.map((item) => (
              <div data-folder={item.kind === 'folder' ? item.id : undefined}>
                {item.kind === 'folder' ? (
                  <>
                    <button
                      type="button"
                      data-folder-toggle={item.id}
                      aria-expanded="true"
                      class:list={[
                        'explorer-row explorer-folder-row py-[6px] text-left font-mono text-[13px]',
                        item.activeWhen?.(currentPath)
                          ? 'bg-slate-200 text-slate-950'
                          : 'text-slate-600 hover:bg-slate-100 hover:text-slate-950',
                      ]}
                    >
                      <HugeIcon name="caret-down" class="explorer-caret text-slate-500" />
                      <span class="explorer-icon text-slate-500">
                        <HugeIcon name="folder-open" class="folder-icon-open" />
                        <HugeIcon name="folder" class="folder-icon-closed" />
                      </span>
                      <span>{item.file}</span>
                    </button>
                    <div class="mt-0.5 space-y-0.5" data-folder-children={item.id}>
                      {item.children.map((child) => (
                        <a
                          href={child.href}
                          class:list={[
                            'explorer-row explorer-row--child py-[5px] font-mono text-[13px] no-underline',
                            isActive(child)
                              ? 'bg-slate-200 text-slate-950'
                              : 'text-slate-600 hover:bg-slate-100 hover:text-slate-950',
                          ]}
                        >
                          <span class="explorer-caret" aria-hidden="true" />
                          {child.icon.type === 'brand' ? (
                            <span class="brand-icon explorer-icon text-slate-500" set:html={BRAND_ICONS[child.icon.name]} />
                          ) : (
                            <HugeIcon name={child.icon.name} class="explorer-icon text-slate-500" />
                          )}
                          <span>{child.file}</span>
                        </a>
                      ))}
                    </div>
                  </>
                ) : (
                  <a
                    href={item.href}
                    target={item.external || isExternal(item.href) ? '_blank' : undefined}
                    rel={item.external || isExternal(item.href) ? 'noreferrer' : undefined}
                    class:list={[
                      'explorer-row group py-[6px] font-mono text-[13px] no-underline',
                      isActive(item)
                        ? 'bg-slate-200 text-slate-950'
                        : 'text-slate-600 hover:bg-slate-100 hover:text-slate-950',
                    ]}
                  >
                    <span class="explorer-caret" aria-hidden="true" />
                    {item.icon.type === 'brand' ? (
                      <span class="brand-icon explorer-icon text-slate-500" set:html={BRAND_ICONS[item.icon.name]} />
                    ) : (
                      <HugeIcon name={item.icon.name} class="explorer-icon text-slate-500" />
                    )}
                    <span>{item.file}</span>
                    {item.openHint && <HugeIcon name="external" class="ml-auto opacity-0 transition-opacity group-hover:opacity-100" size={13} />}
                  </a>
                )}
              </div>
            ))
          }
        </nav>
      </section>
    </aside>

    <main class="flex min-h-0 min-w-0 flex-col overflow-hidden bg-panel [background-image:linear-gradient(90deg,rgba(15,23,42,0.03)_1px,transparent_1px)] [background-size:64px_64px]">
      <nav class="flex shrink-0 items-stretch border-b border-line bg-[#fbfcff]">
        <div class="thin-scrollbar flex min-w-0 flex-1 overflow-x-auto">
          {
            tabLinks.map((l) => (
              <a
                href={l.href}
                class:list={[
                  'tab-row shrink-0 border-r border-line px-3.5 py-[10px] font-mono text-xs no-underline',
                  isActive(l)
                    ? 'bg-white text-slate-950 shadow-[inset_0_-2px_0_var(--color-ink)]'
                    : 'text-muted hover:text-slate-950',
                ]}
              >
                {l.icon.type === 'brand' ? (
                  <span class="brand-icon tab-icon text-slate-500" set:html={BRAND_ICONS[l.icon.name]} />
                ) : (
                  <HugeIcon name={l.icon.name} class="tab-icon text-slate-500" />
                )}
                {l.file}
              </a>
            ))
          }
        </div>
        <button
          type="button"
          class="hidden shrink-0 border-l border-line bg-[#fbfcff] px-3.5 py-[10px] font-mono text-xs text-muted hover:bg-white hover:text-slate-950 lg:block"
          data-toggle-rail
          aria-controls="runtime-rail"
          aria-expanded="true"
        >
          hide right rail
        </button>
      </nav>

      <div class="thin-scrollbar min-h-0 flex-1 overflow-y-auto px-[clamp(22px,5vw,78px)] pt-[38px] pb-[70px]">
        <div class="mb-[18px] font-mono text-xs text-slate-500">{crumb}</div>
        <slot />
      </div>
    </main>

    <RuntimeRail />
  </div>

  <footer class="studio-statusbar flex min-w-0 items-center justify-between gap-3 border-t border-line bg-white px-3 font-mono text-[12px] text-slate-600">
    <div class="flex min-w-0 items-center gap-3 overflow-hidden">
      <a
        href="https://time.is/Hanoi"
        target="_blank"
        rel="noreferrer"
        class="whitespace-nowrap text-slate-700 underline decoration-slate-300 underline-offset-3 hover:text-slate-950"
        data-local-time-link
      >
        Hanoi <span data-local-time>--:--</span> <span class="text-slate-400" data-local-time-diff></span>
      </a>
      <a
        href={lastCommitUrl}
        target="_blank"
        rel="noreferrer"
        class="hidden whitespace-nowrap text-slate-950 underline decoration-slate-300 underline-offset-3 hover:decoration-slate-950 sm:inline"
        title="View last commit on GitHub"
      >
        #{lastCommit}
      </a>
      <span class="vn-badge hidden whitespace-nowrap sm:inline-flex" title="Made in Vietnam">
        <span aria-hidden="true">🇻🇳</span>
        made in Vietnam
      </span>
    </div>
    <label class="flex shrink-0 items-center gap-1 whitespace-nowrap">
      <span class="hidden sm:inline">version</span>
      <select class="status-select" data-version-select aria-label="Open site version">
        {SITE_VERSIONS.map((version) => (
          <option value={version.value} data-href={version.href} selected={version.current}>
            {version.label}
          </option>
        ))}
      </select>
    </label>
  </footer>
</div>

<script is:inline>
  function initStudioShell() {
    const root = document.documentElement
    const toolbarMarkup = `<span class="code-toolbar ec-code-toolbar"><label><span class="hidden sm:inline">theme</span><select data-code-theme-select class="status-select"><option value="github-light-default">light</option><option value="github-dark-default">dark</option></select></label><label><span class="hidden sm:inline">font</span><select data-code-font-select class="status-select"><option value="ui-mono">ui-mono</option><option value="jetbrains">jetbrains</option><option value="sfmono">sfmono</option></select></label></span>`

    const syncCodeControls = () => {
      const theme = localStorage.getItem('leohuynh:code-theme') || 'github-light-default'
      const font = localStorage.getItem('leohuynh:code-font') || 'ui-mono'
      root.dataset.theme = theme
      root.dataset.codeFont = font
      document.querySelectorAll('[data-code-theme-select]').forEach((select) => {
        select.value = theme
      })
      document.querySelectorAll('[data-code-font-select]').forEach((select) => {
        select.value = font
      })
    }

    document.querySelectorAll('.expressive-code figure.frame').forEach((frame) => {
      if (frame.querySelector('.ec-code-toolbar')) return
      frame.insertAdjacentHTML('afterbegin', toolbarMarkup)
    })

    syncCodeControls()
    if (!window.__leohuynhCodeControlsBound) {
      window.__leohuynhCodeControlsBound = true
      document.addEventListener('change', (event) => {
        const target = event.target
        if (!(target instanceof HTMLSelectElement)) return
        if (target.matches('[data-code-theme-select]')) {
          localStorage.setItem('leohuynh:code-theme', target.value)
          syncCodeControls()
        }
        if (target.matches('[data-code-font-select]')) {
          localStorage.setItem('leohuynh:code-font', target.value)
          syncCodeControls()
        }
        if (target.matches('[data-version-select]')) {
          const option = target.selectedOptions[0]
          const href = option?.dataset.href
          if (target.value !== 'latest' && href) window.open(href, '_blank', 'noopener,noreferrer')
          target.value = 'latest'
        }
      })
    }

    document.querySelectorAll('.studio-shell').forEach((shell) => {
      const toggle = shell.querySelector('[data-toggle-rail]')
      const saved = root.dataset.rail || localStorage.getItem('leohuynh:right-rail') || 'visible'
      const setRail = (state) => {
        shell.dataset.rail = state
        root.dataset.rail = state
        if (toggle) {
          toggle.textContent = state === 'hidden' ? 'show right rail' : 'hide right rail'
          toggle.setAttribute('aria-expanded', String(state !== 'hidden'))
        }
        localStorage.setItem('leohuynh:right-rail', state)
      }
      setRail(saved)
      if (toggle && !toggle.dataset.bound) {
        toggle.dataset.bound = 'true'
        toggle.addEventListener('click', () => {
          setRail((root.dataset.rail || shell.dataset.rail) === 'hidden' ? 'visible' : 'hidden')
        })
      }

      shell.querySelectorAll('[data-folder-toggle]').forEach((button) => {
        if (button.dataset.bound) return
        button.dataset.bound = 'true'
        const id = button.getAttribute('data-folder-toggle')
        const children = shell.querySelector(`[data-folder-children="${id}"]`)
        const caret = button.querySelector('.explorer-caret')
        const setOpen = (open) => {
          button.setAttribute('aria-expanded', String(open))
          if (children) children.hidden = !open
          if (caret) caret.style.transform = open ? 'rotate(0deg)' : 'rotate(-90deg)'
        }
        setOpen(true)
        button.addEventListener('click', () => {
          setOpen(button.getAttribute('aria-expanded') !== 'true')
        })
      })

      const timeEl = shell.querySelector('[data-local-time]')
      const diffEl = shell.querySelector('[data-local-time-diff]')
      const updateTime = () => {
        if (!timeEl) return
        const date = new Date()
        const hanoiOffset = -420
        const visitorOffset = date.getTimezoneOffset()
        const hoursDiff = (visitorOffset - hanoiOffset) / 60
        const diff = hoursDiff === 0 ? 'same time' : hoursDiff > 0 ? `${hoursDiff}h ahead` : `${Math.abs(hoursDiff)}h behind`
        timeEl.textContent = new Intl.DateTimeFormat('en-US', {
          timeZone: 'Asia/Ho_Chi_Minh',
          hour: '2-digit',
          minute: '2-digit',
          hour12: true,
          timeZoneName: 'short',
        }).format(date)
        if (diffEl) diffEl.textContent = `- ${diff}`
      }
      updateTime()
      if (!shell.dataset.timeBound) {
        shell.dataset.timeBound = 'true'
        setInterval(updateTime, 30_000)
      }
    })
  }

  initStudioShell()
  document.addEventListener('astro:page-load', initStudioShell)
</script>
