---
import { getCollection, render } from 'astro:content'
import Twemoji from '~/components/mdx/Twemoji.astro'
import StudioShell from '~/components/studio/StudioShell.astro'
import Reactions from '~/components/widgets/Reactions'
import ViewsCounter from '~/components/widgets/ViewsCounter'
import { isPublished, tagSlug } from '~/lib/content'
import BaseLayout from '~/layouts/BaseLayout.astro'

// Slug parity: id = filename (no nested dirs) → `/blog/<slug>` exactly as legacy.
export async function getStaticPaths() {
  const posts = await getCollection('blog', isPublished)
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }))
}

const { post } = Astro.props
const { Content } = await render(post)
const { title, summary, date, lastmod, tags, images, canonicalUrl } = post.data
const ogImage = Array.isArray(images) ? images[0] : images
const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<BaseLayout
  title={title}
  description={summary}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  ogType="article"
  publishedTime={date.toISOString()}
>
  <StudioShell active="/blog" crumb={`~/leohuynh.dev/blog/${post.id}`}>
    <article class="prose">
      <h1>{title}</h1>
      <div class="mb-8 flex flex-wrap items-center gap-3 font-mono text-xs text-muted not-prose">
        <time datetime={date.toISOString()}>{dateFmt.format(date)}</time>
        {
          lastmod && (
            <span>· updated {dateFmt.format(new Date(lastmod))}</span>
          )
        }
        <span>·</span>
        <ViewsCounter type="blog" slug={post.id} client:load />
        {
          tags.map((tag) => (
            <a
              href={`/tags/${tagSlug(tag)}`}
              class="rounded-full border border-line px-2 py-0.5 text-code-blue no-underline"
            >
              #{tag}
            </a>
          ))
        }
      </div>
      <Content components={{ Twemoji }} />
      <div class="mt-12 flex flex-col gap-3 border-t border-line pt-6 not-prose">
        <span class="font-mono text-[11px] uppercase tracking-[0.08em] text-muted">
          react to this post
        </span>
        <Reactions type="blog" slug={post.id} client:visible />
      </div>
    </article>
  </StudioShell>
</BaseLayout>
